<form class="janus7-page j7-atmo-surface">
  {{#if notReady}}
    <div class="janus7-loading">
      <h3><i class="fas fa-spinner fa-spin"></i> Atmosphere nicht bereit</h3>
      <p>Phase-5 Atmosphere ist nicht initialisiert oder deaktiviert.</p>
    </div>
  {{else}}

  <header class="janus7-toolbar">
    <div class="janus7-toolbar__left">
      <h2 class="janus7-title"><i class="fas fa-music"></i> Atmosphere DJ</h2>
    </div>
    <div class="janus7-toolbar__right">
      <button type="button" class="janus-btn" data-action="stopAll"><i class="fas fa-stop"></i> Stop All</button>
      <button type="button" class="janus-btn" data-action="refresh"><i class="fas fa-sync"></i> Refresh</button>
    </div>
  </header>

  <section class="janus7-card">
    <div class="j7-card-head">
      <div class="j7-card-head__copy">
        <h3><i class="fas fa-sliders-h"></i> Steuerung</h3>
        <p class="j7-card-head__hint">Master-Client, Lautst&auml;rke und automatische Quellen zentral steuern.</p>
      </div>
    </div>

    <div class="j7-status-grid">
      <div class="kpi">
        <div class="kpi__label">Aktiver Mood</div>
        <div class="kpi__value">{{#if activeMoodId}}{{activeMoodId}}{{else}}-{{/if}}</div>
      </div>
      <div class="kpi">
        <div class="kpi__label">Master Client</div>
        <div class="kpi__value">{{#if masterClientUserId}}{{masterClientUserId}}{{else}}Auto{{/if}}</div>
      </div>
      <div class="kpi">
        <div class="kpi__label">Auto-Quellen</div>
        <div class="kpi__value">{{#if status.autoFromCalendar}}K{{/if}}{{#if status.autoFromEvents}}E{{/if}}{{#if status.autoFromLocation}}O{{/if}}{{#unless status.autoFromCalendar}}{{#unless status.autoFromEvents}}{{#unless status.autoFromLocation}}Aus{{/unless}}{{/unless}}{{/unless}}</div>
      </div>
    </div>

    <div class="j7-form-grid-3">
      <div class="janus7-formrow">
        <label>Master Client</label>
        <select name="masterClientUserId">
          <option value="" {{#unless masterClientUserId}}selected{{/unless}}>(auto)</option>
          {{#each users}}
            <option value="{{id}}" {{#if (eq id ../masterClientUserId)}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
      </div>

      <div class="janus7-formrow">
        <label>Master Volume ({{volPct}}%)</label>
        <input name="volume" type="range" min="0" max="100" value="{{volPct}}"/>
      </div>

      <div class="janus7-formrow">
        <label>Auto</label>
        <div class="j7-toggle-list">
          <label><input name="autoCalendar" type="checkbox" {{#if status.autoFromCalendar}}checked{{/if}}/> Kalender</label>
          <label><input name="autoEvents" type="checkbox" {{#if status.autoFromEvents}}checked{{/if}}/> Events</label>
          <label><input name="autoLocation" type="checkbox" {{#if status.autoFromLocation}}checked{{/if}}/> Ort</label>
        </div>
      </div>
    </div>
  </section>

  <section class="janus7-card">
    <div class="j7-card-head">
      <div class="j7-card-head__copy">
        <h3><i class="fas fa-th-large"></i> Moods</h3>
        <p class="j7-card-head__hint">Direkter Zugriff auf alle bekannten Atmosph&auml;ren.</p>
      </div>
    </div>
    <div class="janus7-mood-grid">
      {{#each moods}}
        <button type="button" class="janus7-mood {{#if isActive}}is-active{{/if}}" data-action="applyMood" data-mood-id="{{id}}">
          <div class="janus7-mood__name">{{name}}</div>
          {{#if description}}<div class="janus7-mood__desc">{{description}}</div>{{/if}}
        </button>
      {{/each}}
    </div>
  </section>

  {{/if}}
</form>
