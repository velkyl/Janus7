<div class="janus7-ki-roundtrip">
  {{#if notReady}}
    <p>{{localize "JANUS7.UI.NotReady"}}</p>
  {{else}}
    <div class="form-group">
      <label><strong>KI Bundle Export</strong></label>
      <div class="j7-export-modes">
        <button type="button" data-action="exportMode" data-mode="lite"
          class="janus7-btn j7-mode-btn {{#if (eq activeMode 'lite')}}j7-mode-btn--active{{/if}}"
          title="Nur State-Kern: Zeit, Scoring, Atmosphäre, Foundry-Links">
          Lite
        </button>
        <button type="button" data-action="exportMode" data-mode="week"
          class="janus7-btn j7-mode-btn {{#if (eq activeMode 'week')}}j7-mode-btn--active{{/if}}"
          title="+ Akademie-Daten: Lektionen, NPCs, Kalender-Woche">
          Week
        </button>
        <button type="button" data-action="exportMode" data-mode="full"
          class="janus7-btn j7-mode-btn {{#if (eq activeMode 'full')}}j7-mode-btn--active{{/if}}"
          title="Vollständig: + Referenzen, Knowledge-Links, Art-Assets">
          Full
        </button>
        <span class="j7-spacer"></span>
        <button type="button" data-action="exportJson" class="janus7-btn" title="In Textarea laden + Clipboard">
          <i class="fas fa-copy"></i> Kopieren
        </button>
        <button type="button" data-action="exportFile" class="janus7-btn" title="Als Datei herunterladen">
          <i class="fas fa-download"></i> Download
        </button>
      </div>
      <textarea name="ki-json" class="j7-ki-textarea" spellcheck="false">{{bundleJsonRaw}}</textarea>
      <div class="j7-field-hint">
        Modus: <strong>{{activeMode}}</strong>
        {{#if jsonSize}}— {{jsonSize}} Zeichen{{/if}}
      </div>
    </div>

    <div class="form-group j7-form-mt">
      <label><strong>Diff Preview</strong></label>
      {{#if previewWarning}}
      <div class="j7-warning">
        <i class="fas fa-triangle-exclamation"></i> {{previewWarning}}
      </div>
      {{/if}}


      {{#if downtimeDetected}}
      <div class="j7-downtime-warning">
        <strong>⏱️ Zeitsprung erkannt ({{downtimeDays}} Tage).</strong>
        <label class="j7-label-block">
          <input type="checkbox" name="simulate-downtime" {{#if simulateDowntimeDefault}}checked{{/if}}>
          Regulären Unterricht simulieren &amp; Montage-Slot erzeugen?
        </label>
      </div>
      {{/if}}

      <div class="j7-diff-meta">
        <span>Diffs: <strong>{{diffCount}}</strong></span>
        <span>Ausgewählt: <strong>{{diffSelectedCount}}</strong></span>
      </div>

      <div class="j7-diff-list">
        {{#if diffs.length}}
          <ul class="j7-reset-list">
          {{#each diffs}}
            <li class="j7-diff-entry{{#if this.missingReference}} j7-diff-warn{{/if}}{{#if this.invalidSkill}} j7-diff-error{{/if}}">
              <input type="checkbox"
                class="import-toggle"
                data-action="toggleDiff"
                data-diff-idx="{{this._uiIndex}}"
                data-id="{{this.id}}"
                {{#if this.selected}}checked{{/if}}
              />
              <div class="j7-diff-value">
                <div>
                  <strong>{{this.type}}</strong> · {{this.op}} · {{this.path}}
                  {{#if this.autoCorrected}}<em class="j7-auto-corrected"> · autoCorrected</em>{{/if}}
                  {{#if this.missingReference}}<em class="j7-diff-missing"> · missingReference</em>{{/if}}
                  {{#if this.invalidSkill}}<em class="j7-diff-invalid"> · invalidSkill</em>{{/if}}
                </div>
                {{#if this.invalidSkill}}
                <div class="j7-skill-fallback-row">
                  <span>KI-Talent: <strong>{{this.invalidSkillValue}}</strong></span>
                  <select class="skill-fallback-dropdown" data-id="{{this.id}}">
                    {{#each this.skillFallbackOptions}}
                      <option value="{{this}}">{{this}}</option>
                    {{/each}}
                  </select>
                </div>
                {{/if}}
              </div>
            </li>
          {{/each}}
          </ul>
        {{else}}
          <div class="j7-field-hint j7-empty-hint">Keine Änderungen (oder noch kein Preview).</div>
        {{/if}}
      </div>

      <div class="j7-form-mt-sm">
        <button type="button" data-action="preview" class="janus7-btn">
          <i class="fas fa-search"></i> Preview
        </button>
        <button type="button" data-action="selectAllDiffs" class="janus7-btn" title="Alle Diffs auswählen">
          <i class="fas fa-check-double"></i> Alle
        </button>
        <button type="button" data-action="selectNoneDiffs" class="janus7-btn" title="Alle Diffs abwählen">
          <i class="fas fa-ban"></i> Keine
        </button>
        <span class="j7-spacer"></span>
        <button type="button" data-action="applySelected" class="janus7-btn" {{#unless isGM}}disabled{{/unless}} title="Nur markierte Elemente anwenden">
          <i class="fas fa-filter"></i> Nur markierte
        </button>
        <button type="button" data-action="apply" class="janus7-btn" {{#unless isGM}}disabled{{/unless}} title="Markierte Elemente importieren">
          <i class="fas fa-check"></i> Importieren
        </button>
      </div>
    </div>

    <div class="form-group j7-form-mt">
      <label><strong>Import from Inbox</strong></label>
      <input type="text" name="ki-file-name" placeholder="Dateiname z.B. ki_export_123.json" class="j7-input-wide" />
      <button type="button" data-action="loadFile" class="janus7-btn">Load</button>
      <button type="button" data-action="browseFile" class="janus7-btn">Browse…</button>
    </div>

    {{#if history.length}}
    <div class="form-group j7-form-mt">
      <label><strong>Import History</strong></label>
      <ul class="j7-history-list">
        {{#each history}}
          <li class="j7-history-item">
            <span class="j7-history-ts">{{this.timestamp}}</span> —
            <span class="j7-history-status {{#if this.applied}}j7-status-ok{{else}}j7-status-fail{{/if}}">
              {{#if this.applied}}✅ applied{{else}}❌ failed{{/if}}
            </span>
            ({{this.diffs.length}} changes)
            {{#if this.backup}}<small>[backup: {{this.backup}}]</small>{{/if}}
            {{#if this.error}}<small class="j7-text-error">{{this.error}}</small>{{/if}}
          </li>
        {{/each}}
      </ul>
    </div>
    {{/if}}
  {{/if}}
</div>
