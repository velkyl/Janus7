<form class="janus7-page j7-social-surface">
  {{#if notReady}}
    <div class="janus7-loading">
      <h3><i class="fas fa-spinner fa-spin"></i> Social nicht bereit</h3>
      <p>Phase-4 Simulation ist noch nicht initialisiert.</p>
    </div>
  {{else}}

  <header class="janus7-toolbar">
    <div class="janus7-toolbar__left">
      <h2 class="janus7-title"><i class="fas fa-comments"></i> Social</h2>
    </div>
    <div class="janus7-toolbar__right">
      <button type="button" class="janus-btn" data-action="refresh"><i class="fas fa-sync"></i> Refresh</button>
    </div>
  </header>

  <section class="janus7-card">
    <div class="j7-card-head">
      <div class="j7-card-head__copy">
        <h3><i class="fas fa-exchange-alt"></i> Beziehung</h3>
        <p class="j7-card-head__hint">Attitude zwischen Akteuren lesen und direkt anpassen.</p>
      </div>
    </div>

    <div class="j7-form-grid-2">
      <div class="janus7-formrow">
        <label>Von (NPC/SC)</label>
        <select name="fromId">
          <optgroup label="NPCs">
            {{#each npcs}}
              <option value="{{id}}" {{#if (eq id ../fromId)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </optgroup>
          <optgroup label="SCs">
            {{#each pcs}}
              <option value="{{id}}" {{#if (eq id ../fromId)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </optgroup>
        </select>
      </div>

      <div class="janus7-formrow">
        <label>Zu (NPC/SC)</label>
        <select name="toId">
          <optgroup label="SCs">
            {{#each pcs}}
              <option value="{{id}}" {{#if (eq id ../toId)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </optgroup>
          <optgroup label="NPCs">
            {{#each npcs}}
              <option value="{{id}}" {{#if (eq id ../toId)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </optgroup>
        </select>
      </div>
    </div>

    <div class="janus7-kpi">
      <div class="kpi">
        <div class="kpi__label">Attitude</div>
        <div class="kpi__value">{{attitude}}</div>
      </div>

      <div class="kpi">
        <div class="kpi__label">Anpassen</div>
        <div class="kpi__actions">
          <button type="button" class="janus-btn" data-action="adjust" data-delta="-1">-1</button>
          <button type="button" class="janus-btn" data-action="adjust" data-delta="+1">+1</button>
          <button type="button" class="janus-btn" data-action="adjust" data-delta="+5">+5</button>
        </div>
      </div>
    </div>
  </section>

  <section class="janus7-card">
    <div class="j7-card-head">
      <div class="j7-card-head__copy">
        <h3><i class="fas fa-list"></i> Ausgehende Beziehungen</h3>
        <p class="j7-card-head__hint">Alle aktuell bekannten Zielwerte des gew&auml;hlten Ausgangscharakters.</p>
      </div>
    </div>
    <div class="janus7-table-wrap">
      <table class="janus7-table">
        <thead><tr><th>Zu</th><th class="num">Wert</th></tr></thead>
        <tbody>
          {{#if outgoing.length}}
            {{#each outgoing}}
              <tr><td>{{toName}}</td><td class="num">{{value}}</td></tr>
            {{/each}}
          {{else}}
            <tr><td colspan="2" class="janus7-muted">Keine ausgehenden Beziehungen f&uuml;r die aktuelle Auswahl gefunden.</td></tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </section>


  <section class="janus7-card">
    <div class="j7-card-head">
      <div class="j7-card-head__copy">
        <h3><i class="fas fa-bookmark"></i> Social-Story-Hook Queue</h3>
        <p class="j7-card-head__hint">Systemnahe Uebersicht der vorgemerkten Social-Hooks mit kleinem GM-Lebenszyklus.</p>
      </div>
    </div>
    <div class="janus7-kpi">
      <div class="kpi">
        <div class="kpi__label">Gesamt</div>
        <div class="kpi__value">{{storyHookQueue.summary.total}}</div>
      </div>
      <div class="kpi">
        <div class="kpi__label">Vorgemerkt</div>
        <div class="kpi__value">{{storyHookQueue.summary.queued}}</div>
      </div>
      <div class="kpi">
        <div class="kpi__label">Abgeschlossen</div>
        <div class="kpi__value">{{storyHookQueue.summary.completed}}</div>
      </div>
      <div class="kpi">
        <div class="kpi__label">Verworfen</div>
        <div class="kpi__value">{{storyHookQueue.summary.discarded}}</div>
      </div>
    </div>
    <div class="janus7-table-wrap">
      <table class="janus7-table">
        <thead><tr><th>Hook</th><th>Kontext</th><th>Status</th><th>Aktionen</th></tr></thead>
        <tbody>
          {{#if storyHookQueue.items.length}}
            {{#each storyHookQueue.items}}
              <tr>
                <td>
                  <strong>{{title}}</strong>
                  <div class="janus7-muted">{{detail}}</div>
                </td>
                <td>{{fromName}} -> {{toName}} · {{priorityLabel}}</td>
                <td>{{statusLabel}}<div class="janus7-muted">{{updatedAtLabel}}</div></td>
                <td>
                  {{#if ../isGM}}
                    <div class="kpi__actions">
                      <button type="button" class="janus-btn" data-action="executeCommand" data-command-id="setSocialStoryHookStatus" data-hook-id="{{hookId}}" data-status="completed" {{#unless isQueued}}disabled{{/unless}}>Abschliessen</button>
                      <button type="button" class="janus-btn" data-action="executeCommand" data-command-id="setSocialStoryHookStatus" data-hook-id="{{hookId}}" data-status="discarded" {{#unless isQueued}}disabled{{/unless}}>Verwerfen</button>
                      <button type="button" class="janus-btn" data-action="executeCommand" data-command-id="setSocialStoryHookStatus" data-hook-id="{{hookId}}" data-status="queued" {{#if isQueued}}disabled{{/if}}>Wieder oeffnen</button>
                    </div>
                  {{else}}
                    <span class="janus7-muted">Nur GM</span>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          {{else}}
            <tr><td colspan="4" class="janus7-muted">Noch keine Social-Story-Hooks vorgemerkt.</td></tr>
          {{/if}}
        </tbody>
      </table>
    </div>
    {{#if storyHookQueue.history.length}}
      <div class="janus7-muted" style="margin-top:8px;">
        Letzte Aenderungen:
        {{#each storyHookQueue.history}}
          <div>{{actionLabel}} · {{changedAtLabel}}</div>
        {{/each}}
      </div>
    {{/if}}
  </section>


  <section class="janus7-card">
    <div class="j7-card-head">
      <div class="j7-card-head__copy">
        <h3><i class="fas fa-shuffle"></i> Autonome Beziehungs-Events</h3>
        <p class="j7-card-head__hint">Kleine Living-World-Verschiebungen zwischen NSCs, die unabhaengig von den Spielern entstanden sind.</p>
      </div>
    </div>
    <div class="janus7-table-wrap">
      <table class="janus7-table">
        <thead><tr><th>Titel</th><th>Kontext</th><th class="num">Delta</th></tr></thead>
        <tbody>
          {{#if livingHistory.length}}
            {{#each livingHistory}}
              <tr>
                <td>
                  <strong>{{title}}</strong>
                  <div class="janus7-muted">{{summary}}</div>
                </td>
                <td>{{pairLabel}} · {{category}}</td>
                <td class="num">{{deltaLabel}}</td>
              </tr>
            {{/each}}
          {{else}}
            <tr><td colspan="3" class="janus7-muted">Noch keine autonomen Beziehungs-Events protokolliert.</td></tr>
          {{/if}}
        </tbody>
      </table>
    </div>
  </section>

  {{/if}}
</form>
