<section class="janus7-lesson-library flexcol">
  <header class="flexrow" style="gap:8px; align-items:center; margin-bottom:8px;">
    <button type="button" class="janus-btn" data-action="refresh"><i class="fas fa-sync"></i> Refresh</button>
    <button type="button" class="janus-btn" data-action="migrate"><i class="fas fa-file-import"></i> Sync JSON → Items</button>
    <button type="button" class="janus-btn" data-action="createLesson"><i class="fas fa-plus"></i> Neue Lesson</button>
    <span style="margin-left:auto; opacity:.8;">{{count}} Lesson-Dokumente · Typ {{subtype}}</span>
  </header>

  <table class="janus-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Fach</th>
        <th>Teacher</th>
        <th>Jahr</th>
        <th>Dauer</th>
        <th>Lesson ID</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {{#if entries.length}}
        {{#each entries}}
          <tr>
            <td>{{this.name}}</td>
            <td>{{this.subject}}</td>
            <td>{{this.teacherNpcId}}</td>
            <td>{{this.year}}</td>
            <td>{{this.duration}}</td>
            <td><code>{{this.lessonId}}</code></td>
            <td><button type="button" class="janus-btn" data-action="openLesson" data-uuid="{{this.uuid}}"><i class="fas fa-pen"></i> Öffnen</button></td>
          </tr>
        {{/each}}
      {{else}}
        <tr><td colspan="7">Noch keine Lesson-Dokumente vorhanden.</td></tr>
      {{/if}}
    </tbody>
  </table>
</section>
