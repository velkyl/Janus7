<div class="janus7-page j7-manual-runner">
  {{#if hasTests}}
    <div class="j7-manual-runner__header">
      <div class="kpi total"><div class="kpi__label">{{localize 'JANUS7.GuidedManual.Total'}}</div><div class="kpi__value">{{counts.total}}</div></div>
      <div class="kpi pass"><div class="kpi__label">PASS</div><div class="kpi__value">{{counts.pass}}</div></div>
      <div class="kpi fail"><div class="kpi__label">FAIL</div><div class="kpi__value">{{counts.fail}}</div></div>
      <div class="kpi neutral"><div class="kpi__label">SKIP</div><div class="kpi__value">{{counts.skip}}</div></div>
      <div class="kpi warn"><div class="kpi__label">{{localize 'JANUS7.GuidedManual.Pending'}}</div><div class="kpi__value">{{counts.pending}}</div></div>
    </div>

    <div class="j7-manual-runner__layout">
      <aside class="j7-manual-sidebar">
        <div class="j7-manual-sidebar__toolbar">
          <button type="button" class="j7-btn" data-action="refreshList"><i class="fas fa-sync"></i> {{localize 'JANUS7.GuidedManual.Refresh'}}</button>
          <button type="button" class="j7-btn warn" data-action="resetAll"><i class="fas fa-trash"></i> {{localize 'JANUS7.GuidedManual.ResetAll'}}</button>
        </div>
        <div class="j7-manual-list">
          {{#each testList}}
            <button type="button" class="j7-manual-list__item {{#if selected}}is-selected{{/if}} {{statusClass}}" data-action="selectTest" data-test-id="{{id}}">
              <span class="j7-manual-list__idx">{{idx}}</span>
              <span class="j7-manual-list__main">
                <span class="j7-manual-list__title">
                  <span class="j7-manual-list__code"><code>{{id}}</code></span>
                  <span class="j7-manual-list__text">{{title}}</span>
                </span>
                <span class="j7-manual-list__meta">{{statusIcon}} {{statusLabel}} · {{phaseText}}{{#if evidenceCount}} · {{evidenceCount}} {{localize 'JANUS7.GuidedManual.EvidenceShort'}}{{/if}}</span>
              </span>
            </button>
          {{/each}}
        </div>
      </aside>

      <section class="j7-manual-detail">
        {{#if current}}
          <div class="j7-manual-detail__header">
            <div>
              <div class="j7-manual-detail__crumb">{{localize 'JANUS7.GuidedManual.TestLabel'}} {{current.index}} / {{current.total}} · Harness {{harnessVersion}}</div>
              <h2><code>{{current.id}}</code> {{current.title}}</h2>
              <div class="j7-manual-detail__meta">{{current.statusIcon}} {{current.statusLabel}} · {{current.phaseText}} · {{current.suiteClass}}</div>
            </div>
            <div class="j7-manual-detail__nav">
              <button type="button" class="j7-btn" data-action="prevTest"><i class="fas fa-arrow-left"></i> {{localize 'JANUS7.GuidedManual.Previous'}}</button>
              <button type="button" class="j7-btn" data-action="nextTest">{{localize 'JANUS7.GuidedManual.Next'}} <i class="fas fa-arrow-right"></i></button>
            </div>
          </div>

          <div class="j7-manual-detail__grid">
            <div class="janus7-card">
              <h3><i class="fas fa-map-signs"></i> {{localize 'JANUS7.GuidedManual.WhereToFind'}}</h3>
              <p>{{current.whereToFind}}</p>
            </div>
            <div class="janus7-card">
              <h3><i class="fas fa-bullseye"></i> {{localize 'JANUS7.GuidedManual.Expected'}}</h3>
              <p>{{current.expected}}</p>
            </div>
          </div>

          <div class="janus7-card">
            <div class="j7-manual-card__header">
              <h3><i class="fas fa-wand-magic-sparkles"></i> {{localize 'JANUS7.GuidedManual.GuidedMode'}}</h3>
              {{#if current.relevantApp}}
                <button type="button" class="j7-btn" data-action="openRelevantApp"><i class="fas fa-up-right-from-square"></i> {{localize 'JANUS7.GuidedManual.OpenRelevantApp'}}</button>
              {{/if}}
            </div>
            <p class="j7-manual-help">{{localize 'JANUS7.GuidedManual.GuidedModeHelp'}}</p>
          </div>

          <div class="janus7-card">
            <div class="j7-manual-card__header">
              <h3><i class="fas fa-shield-check"></i> {{localize 'JANUS7.GuidedManual.Preconditions'}}</h3>
              <button type="button" class="j7-btn" data-action="runAllChecks"><i class="fas fa-list-check"></i> {{localize 'JANUS7.GuidedManual.RunAllChecks'}}</button>
            </div>
            <div class="j7-manual-checks">
              {{#each current.preconditions}}
                <div class="j7-manual-check {{status}}">
                  <div class="j7-manual-check__main">
                    <div class="j7-manual-check__title">{{idx}}. {{label}}</div>
                    {{#if summary}}<div class="j7-manual-check__meta">{{summary}}</div>{{/if}}
                    {{#if preview}}<pre class="janus7-pre j7-manual-inline-pre">{{preview}}</pre>{{/if}}
                  </div>
                  <div class="j7-manual-check__actions">
                    <span class="j7-manual-badge {{status}}">{{status}}</span>
                    <button type="button" class="j7-btn" data-action="runCheck" data-check-id="{{id}}"><i class="fas fa-play"></i> {{localize 'JANUS7.GuidedManual.RunCheck'}}</button>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>

          {{#if current.requires.length}}
          <div class="janus7-card">
            <h3><i class="fas fa-list-check"></i> {{localize 'JANUS7.GuidedManual.Requirements'}}</h3>
            <ol class="j7-manual-steps">
              {{#each current.requires}}<li>{{this}}</li>{{/each}}
            </ol>
          </div>
          {{/if}}

          <div class="janus7-card">
            <h3><i class="fas fa-route"></i> {{localize 'JANUS7.GuidedManual.GuidedSteps'}}</h3>
            <div class="j7-manual-stepdeck">
              {{#each current.steps}}
                <div class="j7-manual-step {{status}}">
                  <div class="j7-manual-step__main">
                    <div class="j7-manual-step__title">{{idx}}. {{label}}</div>
                    {{#if help}}<div class="j7-manual-step__help">{{help}}</div>{{/if}}
                    {{#if actionSummary}}<div class="j7-manual-step__meta">{{actionSummary}}</div>{{/if}}
                    {{#if actionPreview}}<pre class="janus7-pre j7-manual-inline-pre">{{actionPreview}}</pre>{{/if}}
                    {{#if consoleCommand}}
                      <div class="j7-manual-step__meta">{{localize 'JANUS7.GuidedManual.ConsoleCommandHint'}}</div>
                      <pre class="janus7-pre j7-manual-inline-pre">{{consoleCommand}}</pre>
                    {{/if}}
                  </div>
                  <div class="j7-manual-step__actions">
                    <span class="j7-manual-badge {{status}}">{{status}}</span>
                    {{#if action}}
                      <button type="button" class="j7-btn" data-action="runStep" data-step-id="{{id}}"><i class="fas fa-play"></i> {{buttonLabel}}</button>
                    {{else}}
                      <button type="button" class="j7-btn" data-action="markStepDone" data-step-id="{{id}}"><i class="fas fa-check"></i> {{buttonLabel}}</button>
                    {{/if}}
                  </div>
                </div>
              {{/each}}
            </div>
          </div>

          {{#if current.snippets.length}}
          <div class="janus7-card">
            <h3><i class="fas fa-terminal"></i> {{localize 'JANUS7.GuidedManual.Snippets'}}</h3>
            {{#each current.snippets}}
              <div class="j7-manual-snippet">
                <div class="j7-manual-card__header">
                  {{#if title}}<div class="j7-manual-snippet__title">{{title}}</div>{{/if}}
                  <button type="button" class="j7-btn" data-action="copySnippet" data-snippet-id="{{copyId}}"><i class="fas fa-copy"></i> {{localize 'JANUS7.GuidedManual.CopySnippet'}}</button>
                </div>
                <pre class="janus7-pre">{{code}}</pre>
              </div>
            {{/each}}
          </div>
          {{/if}}

          <div class="janus7-card">
            <div class="j7-manual-card__header">
              <h3><i class="fas fa-magnifying-glass-chart"></i> {{localize 'JANUS7.GuidedManual.Evidence'}}</h3>
              <div class="j7-manual-actions">
                <button type="button" class="j7-btn" data-action="copyEvidence"><i class="fas fa-copy"></i> {{localize 'JANUS7.GuidedManual.CopyEvidence'}}</button>
                <button type="button" class="j7-btn" data-action="clearEvidence"><i class="fas fa-eraser"></i> {{localize 'JANUS7.GuidedManual.ClearEvidence'}}</button>
              </div>
            </div>
            {{#if current.evidence.length}}
              <div class="j7-manual-evidence">
                {{#each current.evidence}}
                  <div class="j7-manual-evidence__item {{#if ok}}ok{{else}}fail{{/if}}">
                    <div class="j7-manual-evidence__meta">{{ts}} · {{kind}} · <code>{{id}}</code></div>
                    <div class="j7-manual-evidence__title">{{label}}</div>
                    <div class="j7-manual-evidence__summary">{{summary}}</div>
                    {{#if preview}}<pre class="janus7-pre j7-manual-inline-pre">{{preview}}</pre>{{/if}}
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p class="j7-manual-help">{{localize 'JANUS7.GuidedManual.NoEvidenceYet'}}</p>
            {{/if}}
          </div>

          <div class="janus7-card">
            <h3><i class="fas fa-pen"></i> {{localize 'JANUS7.GuidedManual.RecordResult'}}</h3>
            <label class="j7-manual-notes__label" for="j7-manual-notes">{{localize 'JANUS7.GuidedManual.Notes'}}</label>
            <textarea id="j7-manual-notes" name="manualNotes" class="j7-manual-notes">{{current.notes}}</textarea>
            <div class="j7-manual-actions">
              <button type="button" class="j7-btn primary" data-action="markPass"><i class="fas fa-check"></i> PASS</button>
              <button type="button" class="j7-btn danger" data-action="markFail"><i class="fas fa-xmark"></i> FAIL</button>
              <button type="button" class="j7-btn" data-action="markSkip"><i class="fas fa-forward"></i> SKIP</button>
              <button type="button" class="j7-btn" data-action="saveNotes"><i class="fas fa-save"></i> {{localize 'JANUS7.GuidedManual.SaveNotesOnly'}}</button>
              <button type="button" class="j7-btn" data-action="clearDecision"><i class="fas fa-eraser"></i> {{localize 'JANUS7.GuidedManual.ClearDecision'}}</button>
            </div>
            {{#if current.updatedAt}}
              <div class="j7-test-detail">{{localize 'JANUS7.GuidedManual.LastSaved'}} {{current.updatedAt}}{{#if current.updatedBy}} · {{current.updatedBy}}{{/if}}</div>
            {{/if}}
          </div>

          <div class="j7-manual-footer-actions">
            <button type="button" class="j7-btn" data-action="openResults"><i class="fas fa-vial"></i> {{localize 'JANUS7.GuidedManual.OpenResults'}}</button>
            <button type="button" class="j7-btn primary" data-action="verifyCatalog"><i class="fas fa-list-check"></i> {{localize 'JANUS7.GuidedManual.VerifyCatalog'}}</button>
          </div>
        {{else}}
          <div class="j7-test-idle"><p>{{localize 'JANUS7.GuidedManual.NoManualTestsFound'}}</p></div>
        {{/if}}
      </section>
    </div>
  {{else}}
    <div class="j7-test-idle">
      <i class="fas fa-route"></i>
      <p>{{localize 'JANUS7.GuidedManual.NoManualTestsRegistered'}}</p>
    </div>
  {{/if}}
</div>
