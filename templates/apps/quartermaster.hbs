<div class="janus-app quartermaster-container" style="display: flex; flex-direction: column; height: 100%;">
  <header class="janus-header" style="flex: 0 0 auto; margin-bottom: 1rem; border-bottom: 2px solid var(--color-border-light-2); padding-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: flex-start;">
    <div>
      <h2>
        <i class="fas fa-coins" style="color: var(--color-primary);"></i> 
        Der Quartiermeister
      </h2>
      <p style="font-style: italic; color: var(--color-text-dark-secondary); font-size: 0.9em; margin-top: -5px;">
        Das Ausrüstungs- und Wirtschafts-Register der Akademie.
      </p>
    </div>
    
    <div style="text-align: right; background: rgba(0,0,0,0.05); padding: 0.5rem; border-radius: 4px; border: 1px solid var(--color-border-light-1);">
      <div style="font-size: 0.8em; color: var(--color-text-dark-secondary); text-transform: uppercase;">Aktiver Einkäufer</div>
      <div style="font-weight: bold; color: {{#if hasBuyer}}var(--color-primary){{else}}red{{/if}};">
        <i class="fas fa-user"></i> {{buyerName}}
      </div>
    </div>
  </header>

  <div class="search-bar" style="display: flex; gap: 0.5rem; margin-bottom: 1rem; flex: 0 0 auto;">
    <input type="text" 
           name="query" 
           placeholder="Suche im Warenbestand (z.B. Langschwert, Heiltrank)..." 
           value="{{query}}"
           autofocus 
           style="flex: 1; padding: 0.75rem; font-size: 1.1em; border: 1px solid var(--color-border-light-1); border-radius: 4px;" />
    
    <select name="typeFilter" style="padding: 0.75rem; border-radius: 4px;">
      <option value="equipment" {{#if (eq typeFilter "equipment")}}selected{{/if}}>Ausrüstung & Tools</option>
      <option value="meleeweapon" {{#if (eq typeFilter "meleeweapon")}}selected{{/if}}>Nahkampfwaffen</option>
      <option value="rangeweapon" {{#if (eq typeFilter "rangeweapon")}}selected{{/if}}>Fernkampfwaffen</option>
      <option value="armor" {{#if (eq typeFilter "armor")}}selected{{/if}}>Rüstungen</option>
      <option value="consumable" {{#if (eq typeFilter "consumable")}}selected{{/if}}>Alchemie (Tränke/Salben)</option>
      <option value="plant" {{#if (eq typeFilter "plant")}}selected{{/if}}>Herbarium (Pflanzen)</option>
      <option value="poison" {{#if (eq typeFilter "poison")}}selected{{/if}}>Gifte & Toxine</option>
    </select>
  </div>
  
  {{#if isBuilding}}
    <div class="janus-flash janus-flash--info">
      <i class="fas fa-spinner fa-spin"></i> Die Lagerbestände in den Kellern werden geprüft...
    </div>
  {{/if}}

  <main class="janus-content results-container" style="flex: 1 1 auto; overflow-y: auto; padding-right: 0.5rem;">
    {{#if results}}
      <table class="janus-table" style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
          <tr style="border-bottom: 2px solid var(--color-border-light-2); color: var(--color-text-dark-secondary);">
            <th style="padding: 0.5rem; width: 40px;"></th>
            <th style="padding: 0.5rem;">Gegenstand</th>
            <th style="padding: 0.5rem; text-align: center;">Typ</th>
            <th style="padding: 0.5rem; text-align: right;">Vorgeschlagener Preis</th>
            <th style="padding: 0.5rem; width: 120px;">Aktion</th>
          </tr>
        </thead>
        <tbody>
          {{#each results}}
            <tr style="border-bottom: 1px solid var(--color-border-light-1); transition: background 0.1s; cursor: pointer;">
              <td style="padding: 0.5rem;">
                <img src="{{img}}" style="width: 32px; height: 32px; object-fit: cover; border: 1px solid #000; border-radius: 3px;" />
              </td>
              <td style="padding: 0.5rem;">
                <div style="font-weight: bold; color: var(--color-text-dark-primary);" title="{{name}}">{{name}}</div>
                <div style="font-size: 0.75em; color: var(--color-text-dark-secondary);">{{packLabel}}</div>
              </td>
              <td style="padding: 0.5rem; text-align: center; font-size: 0.8em; color: var(--color-text-dark-secondary);">
                {{type}}
              </td>
              <td style="padding: 0.5rem; text-align: right; font-weight: bold; color: var(--color-text-dark-primary);">
                {{priceDisplay}}
              </td>
              <td style="padding: 0.5rem; text-align: center;">
                {{#if ../hasBuyer}}
                  <button type="button" class="janus-btn janus-btn--small janus-btn--primary" data-action="buyItem" data-uuid="{{uuid}}" data-price="{{price}}" style="background: var(--color-primary); color: white; border: none; padding: 0.25rem 0.5rem; border-radius: 3px; cursor: pointer;">
                    <i class="fas fa-shopping-cart"></i> Kaufen
                  </button>
                {{else}}
                  <button type="button" class="janus-btn janus-btn--small" data-action="openSheet" data-uuid="{{uuid}}" title="Sheet öffnen">
                    <i class="fas fa-eye"></i> Muster
                  </button>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else if query}}
      <div class="janus-empty-state" style="text-align: center; padding: 3rem 1rem; color: var(--color-text-dark-secondary);">
        <i class="fas fa-box-open fa-3x" style="opacity: 0.2; margin-bottom: 1rem;"></i>
        <p>Der Quartiermeister hat "<strong>{{query}}</strong>" aktuell nicht auf Lager.</p>
      </div>
    {{/if}}
  </main>
</div>
