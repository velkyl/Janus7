{{!--
  JANUS7 Command Center v2 — Spotlight-Style
  File: templates/apps/command-center.hbs
--}}

<div class="janus-command-center janus7-page">

  {{!-- Header --}}
  <div class="janus7-toolbar">
    <div class="janus7-toolbar__left">
      <i class="fas fa-terminal"></i>
      <span class="janus7-title">Command Center</span>
    </div>
    <div class="janus7-toolbar__right">
      <button type="button" class="j7-btn j7-btn-ghost" data-action="openSpotlight" title="Spotlight Search (Ctrl+K)">
        <i class="fas fa-search"></i>
        <span>Suche</span>
        <kbd>Ctrl+K</kbd>
      </button>
      <button type="button" class="j7-beamer-toggle" data-action="toggleBeamerMode" title="Beamer-Modus">
        <i class="fas fa-video"></i>
        Beamer
      </button>
    </div>
  </div>

  {{#unless isGM}}
    <div class="j7-backdrop j7-warn-banner">
      <i class="fas fa-exclamation-triangle"></i>
      {{localize "JANUS7.CommandCenter.GMOnly"}}
    </div>
  {{/unless}}

  {{!-- Kategorie-Filter --}}
  <div class="command-center-filters" role="tablist">
    <button type="button" class="filter-button {{#if (eq selectedCategory 'all')}}active{{/if}}"
      data-action="filterCategory" data-category-id="all" role="tab">
      <i class="fas fa-list"></i> Alle
    </button>
    {{#each commandCategories as |category|}}
      <button type="button" class="filter-button {{#if (eq ../selectedCategory category.id)}}active{{/if}}"
        data-action="filterCategory" data-category-id="{{category.id}}" role="tab">
        <i class="fas {{category.icon}}"></i> {{category.label}}
      </button>
    {{/each}}
  </div>

  {{!-- Inline-Suche --}}
  <div class="j7-search-wrap">
    <div class="j7-library-search">
      <i class="fas fa-search j7-search-icon"></i>
      <input type="text" class="j7-library-search-input" id="j7-cmd-inline-search"
        placeholder="Befehl filtern…" autocomplete="off" spellcheck="false">
    </div>
  </div>

  {{!-- Commands --}}
  <div class="command-center-categories j7-scrollable">
    {{#each commandCategories as |category|}}
      {{#if (or (eq ../selectedCategory 'all') (eq ../selectedCategory category.id))}}
        <div class="command-category j7-tab-content" data-category="{{category.id}}">
          <div class="category-header">
            <h3 class="j7-text-gold j7-category-heading">
              <i class="fas {{category.icon}}"></i> {{category.label}}
            </h3>
            <p class="j7-text-dim j7-category-desc">{{category.description}}</p>
          </div>
          <div class="category-commands">
            {{#each category.commands as |command|}}
              <button type="button" class="command-button {{#unless command.available}}unavailable{{/unless}}"
                data-action="executeCommand"
                data-command-id="{{command.id}}"
                title="{{command.label}}"
                {{#unless command.available}}disabled{{/unless}}>
                <i class="fas {{command.icon}}"></i>
                <span class="command-label">{{command.label}}</span>
              </button>
            {{/each}}
          </div>
        </div>
      {{/if}}
    {{/each}}
  </div>

  <div class="command-center-footer j7-text-dim">
    JANUS7 v{{systemVersion}} &middot; <kbd>Ctrl+K</kbd> Spotlight
  </div>
</div>
