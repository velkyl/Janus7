<div class="janus7-dev-panel">
  {{#if hasActor}}
    <div class="dev-header">
      <div class="actor-info">
        <i class="fas fa-user"></i> {{actor}}
      </div>
      <div class="system-status">
        {{#if systemStatus.contentLoaded}}
          <span class="status-ok"><i class="fas fa-check-circle"></i> Content</span>
        {{else}}
          <span class="status-error"><i class="fas fa-times-circle"></i> Content</span>
        {{/if}}
        {{#if systemStatus.questEngine}}
          <span class="status-ok"><i class="fas fa-check-circle"></i> Quests</span>
        {{else}}
          <span class="status-error"><i class="fas fa-times-circle"></i> Quests</span>
        {{/if}}
      </div>
    </div>

    <div class="dev-content">
      <!-- Event Spawning -->
      <section class="dev-section">
        <h3><i class="fas fa-star"></i> Event Spawning</h3>
        <div class="pool-list">
          {{#each pools}}
            <div class="pool-item" data-pool-name="{{poolName}}">
              <span class="pool-name">{{poolName}}</span>
              <span class="pool-count">({{events.length}} events)</span>
              <button type="button" data-action="spawnEvent" data-pool-name="{{poolName}}" data-actor-id="{{../actorId}}">
                <i class="fas fa-dice"></i> Spawn
              </button>
            </div>
          {{/each}}
        </div>
      </section>

      <!-- Quest Starting -->
      <section class="dev-section">
        <h3><i class="fas fa-book"></i> Quest Starting</h3>
        <div class="quest-list">
          {{#each quests}}
            <div class="quest-item" data-quest-id="{{questId}}">
              <span class="quest-name">{{questId}}</span>
              <span class="quest-title">{{title}}</span>
              <button type="button" data-action="startQuest" data-quest-id="{{questId}}" data-actor-id="{{../actorId}}">
                <i class="fas fa-play"></i> Start
              </button>
            </div>
          {{/each}}
        </div>
      </section>

      <!-- Effect Application -->
      <section class="dev-section">
        <h3><i class="fas fa-bolt"></i> Effect Application</h3>
        <div class="effect-list">
          {{#each effects}}
            <div class="effect-item" data-effect-id="{{effectId}}">
              <code class="effect-expr">{{expr}}</code>
              <span class="effect-desc">{{humanReadable}}</span>
              <button type="button" data-action="applyEffect" data-effect-id="{{effectId}}" data-actor-id="{{../actorId}}">
                <i class="fas fa-wand-magic-sparkles"></i> Apply
              </button>
            </div>
          {{/each}}
        </div>
      </section>

      <!-- State Inspector -->
      <section class="dev-section">
        <h3><i class="fas fa-database"></i> State Inspector</h3>
        <div class="state-inspector">
          <div class="state-block">
            <h4>Player State</h4>
            <pre>{{playerState}}</pre>
          </div>
          <div class="state-block">
            <h4>Quest States</h4>
            <pre>{{questStates}}</pre>
          </div>
          <div class="state-block">
            <h4>Event States</h4>
            <pre>{{eventStates}}</pre>
          </div>
        </div>
        <div class="state-actions">
          <button type="button" data-action="resetState" data-actor-id="{{actorId}}">
            <i class="fas fa-rotate-left"></i> Reset State
          </button>
          <button type="button" data-action="exportState" data-actor-id="{{actorId}}">
            <i class="fas fa-download"></i> Export State
          </button>
        </div>
      </section>
    </div>
  {{else}}
    <div class="error-message">
      <i class="fas fa-exclamation-triangle"></i>
      <p>Kein Character gefunden</p>
    </div>
  {{/if}}
</div>
