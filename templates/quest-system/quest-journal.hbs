<div class="janus7-quest-journal">
  {{#if error}}
    <div class="error-message">
      <i class="fas fa-exclamation-triangle"></i>
      <p>{{error}}</p>
    </div>
  {{else}}
    <div class="quest-journal-summary-grid">
      <div class="summary-card"><span class="summary-value">{{summaryCards.activeQuests}}</span><span class="summary-label">Aktive Quests</span></div>
      <div class="summary-card"><span class="summary-value">{{summaryCards.availableQuests}}</span><span class="summary-label">Verfügbar</span></div>
      <div class="summary-card"><span class="summary-value">{{summaryCards.completedQuests}}</span><span class="summary-label">Abgeschlossen</span></div>
      <div class="summary-card"><span class="summary-value">{{summaryCards.unheardRumors}}</span><span class="summary-label">Neue Gerüchte</span></div>
      <div class="summary-card"><span class="summary-value">{{summaryCards.factions}}</span><span class="summary-label">Fraktionen</span></div>
      <div class="summary-card"><span class="summary-value">{{summaryCards.currentLocationId}}</span><span class="summary-label">Aktueller Ort</span></div>
    </div>

    <div class="quest-journal-layout">
      <div class="quest-journal-main">
        {{#if hasActive}}
          <section class="quest-section active-quests">
            <h3><i class="fas fa-play-circle"></i> Aktive Quests</h3>
            <div class="quest-list">
              {{#each activeQuests}}
                <article class="quest-item active" data-quest-id="{{questId}}">
                  <div class="quest-header">
                    <h4>{{title}}</h4>
                    <div class="quest-actions">
                      <button type="button" data-action="viewQuest" data-quest-id="{{questId}}" data-actor-id="{{../actorId}}"><i class="fas fa-eye"></i></button>
                      <button type="button" data-action="completeQuest" data-quest-id="{{questId}}" data-actor-id="{{../actorId}}"><i class="fas fa-check"></i></button>
                    </div>
                  </div>
                  {{#if description}}<p class="quest-desc">{{description}}</p>{{/if}}
                  <div class="quest-meta">
                    <span><i class="fas fa-map-marker-alt"></i> Knoten: {{state.currentNodeId}}</span>
                    <span><i class="fas fa-history"></i> Historie: {{state.historyCount}}</span>
                    <span><i class="fas fa-clock"></i> {{startedAtLabel}}</span>
                    {{#if hasDeadline}}<span><i class="fas fa-hourglass-half"></i> {{state.deadlineDays}} Tage</span>{{/if}}
                  </div>
                  {{#if tags}}
                    <div class="quest-tags">
                      {{#each tags}}<span class="tag">{{this}}</span>{{/each}}
                    </div>
                  {{/if}}
                </article>
              {{/each}}
            </div>
          </section>
        {{/if}}

        {{#if hasAvailable}}
          <section class="quest-section available-quests">
            <h3><i class="fas fa-scroll"></i> Verfügbare Quests</h3>
            <div class="quest-list">
              {{#each availableQuests}}
                <article class="quest-item available" data-quest-id="{{questId}}">
                  <div class="quest-header">
                    <h4>{{title}}</h4>
                    <button type="button" data-action="startQuest" data-quest-id="{{questId}}" data-actor-id="{{../actorId}}"><i class="fas fa-play"></i> Starten</button>
                  </div>
                  {{#if description}}<p class="quest-desc">{{description}}</p>{{/if}}
                  <div class="quest-meta">
                    {{#if prio}}<span><i class="fas fa-signal"></i> Prio {{prio}}</span>{{/if}}
                    {{#if deadlineDays}}<span><i class="fas fa-hourglass-half"></i> {{deadlineDays}} Tage</span>{{/if}}
                  </div>
                  {{#if tags}}
                    <div class="quest-tags">
                      {{#each tags}}<span class="tag">{{this}}</span>{{/each}}
                    </div>
                  {{/if}}
                </article>
              {{/each}}
            </div>
          </section>
        {{/if}}

        {{#if hasCompleted}}
          <section class="quest-section completed-quests">
            <h3><i class="fas fa-trophy"></i> Abgeschlossene Quests</h3>
            <div class="quest-list">
              {{#each completedQuests}}
                <article class="quest-item completed" data-quest-id="{{questId}}">
                  <div class="quest-header">
                    <h4>{{title}}</h4>
                    <button type="button" data-action="viewQuest" data-quest-id="{{questId}}" data-actor-id="{{../actorId}}"><i class="fas fa-eye"></i></button>
                  </div>
                  <div class="quest-meta">
                    <span><i class="fas fa-check-circle"></i> Abgeschlossen</span>
                    <span><i class="fas fa-clock"></i> {{startedAtLabel}}</span>
                  </div>
                </article>
              {{/each}}
            </div>
          </section>
        {{/if}}
      </div>

      <aside class="quest-journal-sidebar">
        <section class="quest-section rumor-section">
          <h3><i class="fas fa-comments"></i> Gerüchtebrett</h3>
          {{#if hasRumors}}
            <div class="quest-list compact-list">
              {{#each rumors}}
                <article class="rumor-item {{stateClass}}">
                  <div class="rumor-text">{{text}}</div>
                  <div class="quest-meta">
                    <span><i class="fas fa-balance-scale"></i> Wahrheit: {{truthLabel}}</span>
                    <span><i class="fas fa-calendar-times"></i> Verfall: {{decayDays}}</span>
                    <span><i class="fas fa-ear-listen"></i> {{#if heard}}gehört{{else}}neu{{/if}}</span>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <div class="empty-state small"><p>Keine Gerüchte vorhanden.</p></div>
          {{/if}}
        </section>

        <section class="quest-section faction-section">
          <h3><i class="fas fa-shield-halved"></i> Häuser & Zirkel</h3>
          {{#if hasFactions}}
            <div class="quest-list compact-list">
              {{#each factions}}
                <article class="faction-item">
                  <div class="faction-head">
                    <strong>{{name}}</strong>
                    <span class="faction-type">{{type}}</span>
                  </div>
                  <div class="quest-meta">
                    <span><i class="fas fa-star"></i> Punkte: {{pointsLabel}}</span>
                    <span><i class="fas fa-user-check"></i> Ruf: {{reputationLabel}}</span>
                  </div>
                  {{#if rivalry}}<div class="faction-rivalry"><i class="fas fa-bolt"></i> Rivalität: {{rivalry}}</div>{{/if}}
                  {{#if perksText}}<div class="faction-perks"><i class="fas fa-gem"></i> {{perksText}}</div>{{/if}}
                </article>
              {{/each}}
            </div>
          {{else}}
            <div class="empty-state small"><p>Keine Fraktionen geladen.</p></div>
          {{/if}}
        </section>
      </aside>
    </div>
  {{/if}}
</div>
