<div class="janus7-event-popup">
  <div class="event-toolbar">
    <div class="event-toolbar__meta"><i class="fas fa-location-dot"></i> Ort: {{activeLocationId}}</div>
    <button type="button" class="janus-btn" data-action="refreshPopup"><i class="fas fa-sync"></i> Refresh</button>
  </div>
  <div class="event-layout">
    <div class="event-main">
      <div class="event-content">
        <h2 class="event-title">{{event.title}}</h2>
        <div class="event-description">
          <p>{{event.description}}</p>
        </div>

        {{#if hasOptions}}
          <div class="event-options">
            <h3>Optionen</h3>
            {{#each options}}
              <button 
                type="button" 
                class="event-option" 
                data-action="selectOption" 
                data-option-id="{{optionId}}"
                data-actor-id="{{../actorId}}">
                <div class="option-text">{{text}}</div>
                {{#if reqExpr}}<div class="option-req"><i class="fas fa-lock"></i> {{reqExpr}}</div>{{/if}}
                {{#if checkExpr}}<div class="option-check"><i class="fas fa-dice-d20"></i> {{checkExpr}}</div>{{/if}}
                {{#if effectIds}}
                  <div class="option-effects">
                    <i class="fas fa-bolt"></i>
                    {{#each effectIds}}<span class="effect-tag">{{this}}</span>{{/each}}
                  </div>
                {{/if}}
              </button>
            {{/each}}
          </div>
        {{else}}
          <div class="no-options">
            <p><i class="fas fa-info-circle"></i> Keine Optionen verfügbar</p>
            <button type="button" data-action="close">Schließen</button>
          </div>
        {{/if}}
      </div>
    </div>
    <aside class="event-sidebar">
      <section class="event-sidecard">
        <h3><i class="fas fa-bookmark"></i> Aktive Quests</h3>
        {{#if hasActiveQuests}}
          <ul class="event-side-list">
            {{#each activeQuests}}
              <li>
                <strong>{{title}}</strong>
                <div>Knoten: {{currentNodeId}}</div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="event-side-empty">Keine aktiven Quests für diesen Akteur.</p>
        {{/if}}
      </section>

      <section class="event-sidecard">
        <h3><i class="fas fa-comments"></i> Ungelesene Gerüchte</h3>
        {{#if hasRumors}}
          <ul class="event-side-list">
            {{#each availableRumors}}
              <li>{{text}}</li>
            {{/each}}
          </ul>
        {{else}}
          <p class="event-side-empty">Keine neuen Gerüchte.</p>
        {{/if}}
      </section>
    </aside>
  </div>
</div>
