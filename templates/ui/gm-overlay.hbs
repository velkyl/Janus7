<div class="janus7-gm-overlay__outer">
    {{!-- Head Section with Profile/Context --}}
    <header class="janus7-gm-overlay__head">
        <div class="janus7-gm-overlay__context">
            <span class="janus7-gm-overlay__profile-badge" data-profile="{{profile.id}}">
                {{profile.name}}
            </span>
            <h2 class="janus7-gm-overlay__title">{{time.day}} &middot; {{time.phase}}</h2>
            {{#if status.hasAlert}}
                <span class="janus7-gm-overlay__alert pulse" title="Verrat/Plot Events aktiv!">
                    <i class="fas fa-exclamation-triangle"></i>
                </span>
            {{/if}}
        </div>
        <button type="button" class="janus7-gm-overlay__shell-trigger" data-action="openShell" aria-label="Open JANUS Shell">
            <i class="fas fa-terminal"></i>
            <span>Shell</span>
        </button>
    </header>

    {{!-- Stats Grid --}}
    <div class="janus7-gm-overlay__stats-grid">
        <div class="janus7-gm-overlay__stat-item">
            <span class="label">Woche</span>
            <span class="value">{{time.week}}</span>
        </div>
        <div class="janus7-gm-overlay__stat-item">
            <span class="label">Jahr</span>
            <span class="value">{{time.year}} BF</span>
        </div>
        <div class="janus7-gm-overlay__stat-item janus7-gm-overlay__stat-item--leader">
            <span class="label">F&uuml;hrender Zirkel</span>
            <span class="value">{{scoring.leader}}</span>
        </div>
    </div>

    {{!-- Circle Progress / Mini-Leaderboard --}}
    <div class="janus7-gm-overlay__leaderboard">
        {{#each scoring.topCircles}}
            <div class="janus7-gm-overlay__leader-row">
                <span class="circle-name">{{this.name}}</span>
                <span class="circle-score">{{this.score}} AP</span>
                <div class="circle-bar" style="--progress: {{this.progress}}%;"></div>
            </div>
        {{/each}}
    </div>

    {{!-- Action Bar --}}
    <nav class="janus7-gm-overlay__actions">
        <button type="button" class="janus7-gm-overlay__btn" data-action="advanceSlot" title="N&auml;chster Slot (+1)">
            <i class="fas fa-hourglass-half"></i>
            <span>+Slot</span>
        </button>
        <button type="button" class="janus7-gm-overlay__btn" data-action="advanceDay" title="N&auml;chster Tag (+1)">
            <i class="fas fa-sun"></i>
            <span>+Tag</span>
        </button>
        <button type="button" class="janus7-gm-overlay__btn" data-action="openScoring" title="Scoring & Progression">
            <i class="fas fa-chart-line"></i>
            <span>Scores</span>
        </button>
    </nav>
</div>
