{{!--
  JANUS7 Sidebar Tab
  File: templates/sidebar/janus-sidebar.hbs

  Struktur folgt Foundry-nativer .directory / .directory-list Semantik.
  Kein style="..." — alle Stile via janus7-sidebar.css (@layer janus7.sidebar).
--}}

<section class="janus7-sidebar j7-sidebar-shell">
  <header class="j7-sidebar-header">
    <h3 class="header-title">{{title}}</h3>
    {{#if version}}
      <span class="janus7-sidebar-version">v{{version}}</span>
    {{/if}}
  </header>

  {{#if isGM}}
  <div class="j7-sidebar-sections">

    <section class="j7-sidebar-section">
      <h4 class="j7-sidebar-section-title">{{localize 'JANUS7.Sidebar.Section.Apps'}}</h4>
      <div class="janus7-sidebar-btn-group">
        {{#each apps}}
          <button type="button"
            class="control{{#if this.active}} active{{/if}}"
            data-action="openApp"
            data-app="{{this.key}}"
            title="{{this.label}}">
            <i class="{{this.icon}}"></i>
            {{this.label}}
          </button>
        {{/each}}
      </div>
    </section>

    <section class="j7-sidebar-section janus7-sidebar-actions">
      <h4 class="j7-sidebar-section-title">{{localize 'JANUS7.Sidebar.Section.Actions'}}</h4>
      <div class="janus7-sidebar-btn-group">
        {{#each actions}}
          <button type="button"
            class="control"
            data-action="runCommand"
            data-command="{{this.id}}"
            title="{{this.label}}">
            <i class="{{this.icon}}"></i>
            {{this.label}}
          </button>
        {{/each}}
      </div>
    </section>

  </div>
  {{else}}
  <p class="notes">{{localize 'JANUS7.Sidebar.GMOnly'}}</p>
  {{/if}}
</section>
