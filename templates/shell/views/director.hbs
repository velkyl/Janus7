<div class="j7-shell__view j7-shell__view--director">
  <div class="janus7-two-col">
    {{#each view.cards}}
      <article class="j7-shell__card">
        <header class="j7-shell__card-head">
          <div>
            <h3><i class="{{icon}} j7-shell__card-icon" aria-hidden="true"></i><span>{{title}}</span></h3>
            <p>{{description}}</p>
          </div>
        </header>
        {{#if metrics.length}}
          <div class="j7-shell__metrics">
            {{#each metrics}}
              <div class="j7-shell__metric">
                <span>{{label}}</span>
                <strong>{{value}}</strong>
              </div>
            {{/each}}
          </div>
        {{/if}}
        {{#if items.length}}
          <div class="j7-shell__list">
            {{#each items}}
              <div class="j7-shell__list-row">
                <span>{{label}}</span>
                <strong>{{value}}</strong>
              </div>
            {{/each}}
          </div>
        {{/if}}
        {{#if actions.length}}
          <div class="j7-shell__card-actions">
            {{#each actions}}
              {{#if panelId}}
                <button type="button" class="j7-shell__btn" data-action="openPanel" data-panel-id="{{panelId}}"><i class="{{icon}}"></i> {{label}}</button>
              {{else}}
                <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-action-index="{{actionIndex}}" data-card-index="{{../cardIndex}}">
                  <i class="{{icon}}"></i> {{label}}
                </button>
              {{/if}}
            {{/each}}
          </div>
        {{/if}}
      </article>
    {{/each}}
  </div>

  <div class="janus7-two-col j7-mt-sm">
    <!-- Runbook Card -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-route j7-shell__card-icon" aria-hidden="true"></i><span>Runbook</span></h3>
          <p>Workflow & Tagesablauf</p>
        </div>
      </header>
      <div class="j7-shell__metrics">
        {{#if directorRunbook.suggestedAction}}
          <div class="j7-callout">
            <p><strong>Nächste Aktion:</strong> {{directorRunbook.suggestedAction.label}}</p>
            <p class="muted">{{directorRunbook.suggestedAction.reason}}</p>
            <div class="j7-shell__card-actions j7-mt-sm">
              <button type="button" class="j7-shell__btn" data-action="directorRunbookNext"><i class="fas fa-play"></i> Fortsetzen</button>
              <button type="button" class="j7-shell__btn" data-action="{{directorRunbook.suggestedAction.action}}"><i class="fas fa-bolt"></i> Ausführen</button>
            </div>
          </div>
        {{else}}
          <p class="muted">Aktuell keine Runbook Empfehlung.</p>
        {{/if}}

        {{#if directorRunbook.moodSuggestion}}
          <div class="j7-shell__metric j7-mt-sm">
            <span>Mood Suggestion</span>
            <strong>{{directorRunbook.moodSuggestion.moodLabel}}</strong>
          </div>
        {{/if}}

        <div class="j7-shell__card-actions j7-mt-sm" style="flex-wrap: wrap;">
          <button type="button" class="j7-shell__btn" data-action="startDirectorDay"><i class="fas fa-sun"></i> Tagesstart</button>
          <button type="button" class="j7-shell__btn" data-action="directorProcessQueue"><i class="fas fa-list-check"></i> Queue Run</button>
          <button type="button" class="j7-shell__btn" data-action="directorRunLesson"><i class="fas fa-chalkboard-teacher"></i> Lesson Run</button>
          <button type="button" class="j7-shell__btn" data-action="directorApplyMood"><i class="fas fa-music"></i> Mood Apply</button>
        </div>
      </div>
    </article>

    <!-- Workflow Events -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-clipboard-list j7-shell__card-icon" aria-hidden="true"></i><span>Letzte Ereignisse</span></h3>
          <p>Aus dem Workflow Runbook</p>
        </div>
      </header>
      <div class="j7-shell__metrics">
        {{#if directorWorkflow.socialAdvances.length}}
          <ul class="janus7-list">
            {{#each directorWorkflow.socialAdvances}}
              <li><span class="tag">SOCIAL</span> <strong>{{label}}</strong> (Rank {{rank}})</li>
            {{/each}}
          </ul>
        {{else}}
          <div class="j7-empty-state j7-mt-sm">
            <i class="fas fa-users-slash j7-empty-icon"></i>
            <p class="muted">Keine neuen Social Fortschritte erkannt.</p>
          </div>
        {{/if}}

        {{#if directorWorkflow.startedQuest}}
           <div class="j7-callout j7-mt-sm">
             <p><strong>Neue Quest:</strong> {{directorWorkflow.startedQuest.title}} gestartet (#{{directorWorkflow.startedQuest.actorLabel}})</p>
           </div>
        {{else}}
          <div class="j7-empty-state j7-mt-sm">
            <i class="fas fa-scroll j7-empty-icon"></i>
            <p class="muted">Keine aktiven Quest-Hooks im aktuellen Workflow.</p>
          </div>
        {{/if}}

        <div class="j7-shell__card-actions j7-mt-sm">
           <button type="button" class="j7-shell__btn" data-action="directorGenerateQuests"><i class="fas fa-magic"></i> Quests generieren</button>
           <button type="button" class="j7-shell__btn" data-action="directorEvaluateSocial"><i class="fas fa-users-gear"></i> Social Checks</button>
        </div>
      </div>
    </article>
  </div>

  <!-- Status Monitor (Option 11) -->
  <div class="j7-mt-sm">
    <article class="j7-shell__card j7-shell__card--wide">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-heart-pulse j7-shell__card-icon" aria-hidden="true"></i><span>Status Monitor</span></h3>
          <p>Echtzeit-Überwachung der Studenten & Helden</p>
        </div>
      </header>
      <div class="j7-shell__status-grid">
        {{#each playerStats}}
          <div class="j7-shell__status-item">
            <div class="j7-shell__status-actor">
              <strong>{{name}}</strong>
              <div class="j7-shell__status-vitals">
                <span class="j7-badge {{#if (lt lep.value 5)}}j7-badge--danger{{/if}}">LP: {{lep.value}}/{{lep.max}}</span>
                <span class="j7-badge j7-badge--info">AP: {{asp.value}}/{{asp.max}}</span>
                {{#if kap.max}}<span class="j7-badge j7-badge--warning">KP: {{kap.value}}/{{kap.max}}</span>{{/if}}
              </div>
            </div>
            <div class="j7-shell__status-effects">
              {{#each conditions}}
                <span class="j7-tag j7-tag--accent j7-clickable" 
                      data-action="openSheet" 
                      data-uuid="{{lookup (lookup ../../conditionRules label) 'uuid'}}"
                      title="Regel: {{label}} ({{value}})">
                  {{label}} ({{value}})
                </span>
              {{else}}
                <span class="muted small">Keine Zustände</span>
              {{/each}}
            </div>
          </div>
        {{/each}}
      </div>
    </article>
  </div>

  <!-- Regionale Kreaturen (Option 8) -->
  <div class="j7-mt-sm">
    <article class="j7-shell__card j7-shell__card--wide">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-dragon j7-shell__card-icon" aria-hidden="true"></i><span>Regionale Fauna & Flora (Kreaturen)</span></h3>
          <p>Potenzielle Begegnungen aus den Bestiarien & Modulen</p>
        </div>
      </header>
      <div class="j7-shell__status-grid">
        {{#each (slice moduleContent.creatures 0 12)}}
          <div class="j7-shell__status-item">
             <div class="j7-shell__status-actor">
               <img src="{{img}}" style="width: 24px; height: 24px; border-radius: 50%; margin-right: 8px;">
               <strong>{{name}}</strong>
               <span class="j7-badge">{{packLabel}}</span>
             </div>
             <div class="j7-shell__card-actions j7-mt-xs">
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="openSheet" data-uuid="{{uuid}}">
                 <i class="fas fa-eye"></i> Details
               </button>
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="executeShellAction" data-command="importCreature" data-dataset-uuid="{{uuid}}">
                 <i class="fas fa-download"></i> Import
               </button>
             </div>
          </div>
        {{else}}
          <p class="muted j7-p-md">Keine Bestiarien oder regionalen Kreaturen gefunden.</p>
        {{/each}}
      </div>
    </article>
  </div>

  <!-- Kalender & Almanach (Option 15) -->
  <div class="j7-mt-sm">
    <article class="j7-shell__card j7-shell__card--wide">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-calendar-alt j7-shell__card-icon" aria-hidden="true"></i><span>Regionale Ereignisse & Feiertage</span></h3>
          <p>Aktuelle Feste und astronomische Daten aus dem Almanach</p>
        </div>
      </header>
      <div class="j7-shell__status-grid">
        {{#each (slice moduleContent.calendarEvents 0 8)}}
          <div class="j7-shell__status-item j7-shell__status-item--info">
             <div class="j7-shell__status-actor">
               <i class="fas fa-star j7-mr-sm"></i>
               <strong>{{name}}</strong>
               <span class="j7-badge">{{packLabel}}</span>
             </div>
             <div class="j7-shell__card-actions j7-mt-xs">
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="openSheet" data-uuid="{{uuid}}">
                 <i class="fas fa-eye"></i> Nachschlagen
               </button>
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="executeShellAction" data-command="syncCalendarEvent" data-dataset-uuid="{{uuid}}">
                 <i class="fas fa-sync"></i> Synchronisieren
               </button>
             </div>
          </div>
        {{else}}
          <p class="muted j7-p-md">Keine Almanach-Ereignisse in den aktiven Modulen gefunden.</p>
        {{/each}}
      </div>
    </article>
  </div>
</div>
