<div class="j7-shell__view j7-shell__view--people">
  
  <div class="janus7-two-col">
    <!-- Teachers -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-chalkboard-teacher j7-shell__card-icon" aria-hidden="true"></i><span>Lehrkräfte</span></h3>
        </div>
      </header>
      <div class="j7-shell__metrics">
        <div class="j7-dropzone j7-dropzone--medium" data-dropzone="people" data-role="teachers">
          <div class="j7-dropzone__label"><i class="fas fa-user-plus"></i> Actors hier ablegen</div>
        </div>
        {{#if view.peopleView.teachers.length}}
          <ul class="janus7-list j7-mt-sm">
            {{#each view.peopleView.teachers}}
              <li><span class="tag">L</span> <strong>{{name}}</strong></li>
            {{/each}}
          </ul>
        {{else}}
          <p class="muted">Keine Lehrkräfte zugeordnet.</p>
        {{/if}}
      </div>
    </article>

    <!-- Students -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-user-graduate j7-shell__card-icon" aria-hidden="true"></i><span>Schüler</span></h3>
        </div>
      </header>
      <div class="j7-shell__metrics">
        <div class="j7-dropzone j7-dropzone--medium" data-dropzone="people" data-role="students">
          <div class="j7-dropzone__label"><i class="fas fa-user-plus"></i> Actors hier ablegen</div>
        </div>
        {{#if view.peopleView.students.length}}
          <ul class="janus7-list j7-mt-sm">
            {{#each view.peopleView.students}}
              <li><span class="tag">S</span> <strong>{{name}}</strong></li>
            {{/each}}
          </ul>
        {{else}}
          <p class="muted">Keine Schüler zugeordnet.</p>
        {{/if}}
      </div>
    </article>
    
    <!-- NPCs -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-users j7-shell__card-icon" aria-hidden="true"></i><span>Weitere NPCs</span></h3>
        </div>
      </header>
      <div class="j7-shell__metrics">
        <div class="j7-dropzone j7-dropzone--medium" data-dropzone="people" data-role="npcs">
          <div class="j7-dropzone__label"><i class="fas fa-user-plus"></i> Actors hier ablegen</div>
        </div>
        {{#if view.peopleView.npcs.length}}
          <ul class="janus7-list j7-mt-sm">
            {{#each view.peopleView.npcs}}
              <li><span class="tag">NPC</span> <strong>{{name}}</strong></li>
            {{/each}}
          </ul>
        {{else}}
          <p class="muted">Keine NPCs zugeordnet.</p>
        {{/if}}
      </div>
    </article>

    <!-- Gefährten (Option 12) -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-paw j7-shell__card-icon" aria-hidden="true"></i><span>Gefährten & Tiere</span></h3>
          <p>Vertraute, Reittiere & Begleiter aus Modulen</p>
        </div>
      </header>
      <div class="j7-shell__metrics">
        {{#if moduleContent.companions.length}}
          <ul class="janus7-list j7-mt-sm">
            {{#each (slice moduleContent.companions 0 8)}}
              <li class="j7-shell__list-row">
                <span>
                  <img src="{{img}}" style="width: 20px; height: 20px; border-radius: 50%; margin-right: 8px;">
                  <strong>{{name}}</strong>
                </span>
                <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="openSheet" data-uuid="{{uuid}}">
                  <i class="fas fa-eye"></i>
                </button>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="muted">Keine speziellen Begleiter-Module aktiv.</p>
        {{/if}}
      </div>
    </article>
  </div>

  <section class="j7-panel j7-mt-md">
    <h3><i class="fas fa-user-graduate"></i> Alumni-Tracking</h3>
    <p class="j7-text-dim">Read-only Uebersicht plus kleine GM-Verwaltung fuer ehemalige Schueler. Grundlage ist `academy.alumni` im State, nicht das Lore-Archiv.</p>

    <div class="j7-shell__metrics">
      <div><strong>Gesamt:</strong> {{view.alumniView.summary.total}}</div>
      <div><strong>Mentoren:</strong> {{view.alumniView.summary.mentors}}</div>
      <div><strong>Rueckkehr-NSCs:</strong> {{view.alumniView.summary.returned}}</div>
      <div><strong>Inaktiv:</strong> {{view.alumniView.summary.inactive}}</div>
      <div><strong>Mit Bewertungsstand:</strong> {{view.alumniView.summary.graded}}</div>
      <div><strong>Wiedereinsatz-Hinweise:</strong> {{view.alumniView.summary.suggested}}</div>
      <div><strong>Narrative Haken:</strong> {{view.alumniView.summary.narrativeHooks}}</div>
    </div>

    <div class="j7-seed-grid">
      <article class="j7-seed-card">
        <header>
          <strong>Verfolgte Alumni</strong>
        </header>
        {{#if view.alumniView.alumni.length}}
          <ul class="janus7-list">
            {{#each view.alumniView.alumni}}
              <li>
                <div>
                  <strong>{{name}}</strong>
                  <div class="j7-text-dim">{{statusLabel}} · {{graduationLabel}} · {{focusLabel}}{{#if note}} · {{note}}{{/if}}</div>
                  <div class="j7-text-dim">Leistungsstand: {{latestGradeLabel}} · {{latestGradeStatusLabel}} · {{latestGradeEvidenceLabel}}{{#if hasReportCardDraft}} · Zeugnisentwurf vorhanden{{/if}}</div>
                  <div class="j7-text-dim">Pruefungen: {{supportingExamsLabel}}</div>
                </div>
                <div>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setAlumniStatus" data-npc-id="{{npcId}}" data-status="graduated" {{#unless isMentor}}{{#unless isReturned}}{{#unless isInactive}}disabled{{/unless}}{{/unless}}{{/unless}}>Alumni</button>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setAlumniStatus" data-npc-id="{{npcId}}" data-status="mentor" {{#if isMentor}}disabled{{/if}}>Mentor</button>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setAlumniStatus" data-npc-id="{{npcId}}" data-status="returned" {{#if isReturned}}disabled{{/if}}>Rueckkehr</button>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Noch keine Alumni im State erfasst.</p>
        {{/if}}
      </article>

      <article class="j7-seed-card">
        <header>
          <strong>Kandidaten aus NPC-Daten</strong>
        </header>
        {{#if view.alumniView.candidates.length}}
          <ul class="janus7-list">
            {{#each view.alumniView.candidates}}
              <li>
                <div>
                  <strong>{{name}}</strong>
                  <div class="j7-text-dim">{{roleText}}</div>
                </div>
                <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="registerAlumniRecord" data-npc-id="{{id}}" data-status="graduated">Als Alumni markieren</button>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Keine offenen Alumni-Kandidaten aus den aktuellen Schueler-NPCs gefunden.</p>
        {{/if}}
      </article>

      <article class="j7-seed-card">
        <header>
          <strong>Wiedereinsatz-Hinweise</strong>
        </header>
        {{#if view.alumniView.reentrySuggestions.length}}
          <ul class="janus7-list">
            {{#each view.alumniView.reentrySuggestions}}
              <li>
                <div>
                  <strong>{{name}}</strong>
                  <div class="j7-text-dim">{{suggestedRole}} · {{statusLabel}} · Leistungsstand {{latestGradeLabel}}</div>
                  <div class="j7-text-dim">{{rationale}}</div>
                  <div class="j7-text-dim">Narrativer Anschluss: {{narrativeHint}}</div>
                  <div class="j7-text-dim">GM-Fokus: {{focusLabel}}</div>
                </div>
                <div>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setAlumniFocus" data-npc-id="{{npcId}}" data-focus="mentor" {{#if isMentor}}disabled{{/if}}>Mentor vormerken</button>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setAlumniFocus" data-npc-id="{{npcId}}" data-focus="return" {{#if isReturned}}disabled{{/if}}>Rueckkehr priorisieren</button>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setAlumniFocus" data-npc-id="{{npcId}}" data-focus="">Fokus loeschen</button>
                </div>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Noch keine belastbaren Wiedereinsatz-Hinweise aus Alumni- und Zeugnisdaten ableitbar.</p>
        {{/if}}
      </article>

      <article class="j7-seed-card">
        <header>
          <strong>Letzte Aenderungen</strong>
        </header>
        {{#if view.alumniView.recentChanges.length}}
          <ul class="janus7-list">
            {{#each view.alumniView.recentChanges}}
              <li><strong>{{name}}</strong> <span class="j7-text-dim">{{actionLabel}} · {{statusLabel}}</span></li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Noch keine Alumni-Aenderungen protokolliert.</p>
        {{/if}}
      </article>
    </div>
  </section>
</div>
