<div class="janus-session-prep janus7-page">
  <div class="janus7-toolbar">
    <div class="janus7-toolbar__left">
      <i class="fas fa-wand-sparkles"></i>
      <span class="janus7-title">Session Prep</span>
    </div>
    <div class="janus7-toolbar__right">
      <button type="button" class="janus-btn" data-action="executeShellAction" data-view-id="sessionPrep" title="Report neu generieren"><i class="fas fa-sync"></i> Refresh</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="academyOverview"><i class="fas fa-calendar-week"></i> Übersicht</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="atmosphereDJ"><i class="fas fa-music"></i> Atmosphäre</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="academyDataStudio"><i class="fas fa-edit"></i> Data Studio</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="kiRoundtrip"><i class="fas fa-brain"></i> KI</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="kiBackupManager"><i class="fas fa-life-ring"></i> Backups</button>
    </div>
  </div>

  {{#unless view.isGM}}
    <div class="j7-backdrop j7-warn-banner"><i class="fas fa-exclamation-triangle"></i> Nur der GM kann Session Prep sinnvoll nutzen.</div>
  {{/unless}}

  <section class="j7-panel j7-session-prep__hero">
    <div>
      <h3><i class="fas fa-clock"></i> Aktueller Stand</h3>
      <p><strong>Woche {{view.slotRef.week}}</strong> · {{view.slotRef.day}} · {{view.slotRef.phase}}</p>
      <p class="j7-text-dim">Generiert: {{view.generatedAt}}</p>
    </div>
    <div>
      <h4><i class="fas fa-map-marker-alt"></i> Aktiver Ort</h4>
      {{#if view.activeLocation}}
        <p><strong>{{view.activeLocation.name}}</strong></p>
        <p class="j7-text-dim">Mood: {{view.activeLocation.defaultMoodKey}}</p>
      {{else}}
        <p class="j7-text-dim">Kein aktiver Ort gesetzt.</p>
      {{/if}}
    </div>
    <div>
      <h4><i class="fas fa-stethoscope"></i> Technik</h4>
      <p><strong>{{view.diagnostics.health}}</strong></p>
      <p class="j7-text-dim">Warnungen: {{view.diagnostics.warnings.length}}</p>
    </div>
  </section>

  <div class="j7-two-col">
    <section class="j7-panel">
      <h3><i class="fas fa-list-check"></i> Priorisierte To-dos</h3>
      <div class="j7-checklist">
        {{#each view.suggestions as |item|}}
          <article class="j7-checklist__item">
            <div class="j7-checklist__icon"><i class="fas {{item.icon}}"></i></div>
            <div>
              <strong>{{item.title}}</strong>
              <p>{{item.detail}}</p>
            </div>
          </article>
        {{/each}}
      </div>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-music"></i> Mood-Vorschläge</h3>
      <ul class="j7-plain-list">
        {{#if view.suggestedMoods.length}}
          {{#each view.suggestedMoods as |mood|}}
            <li>
              <strong>{{mood.label}}</strong>
              {{#if mood.isActive}}<span class="j7-text-dim"> · aktiv</span>{{/if}}<br>
              <span class="j7-text-dim">{{mood.source}} · {{mood.detail}}</span><br>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyMood" data-mood-id="{{mood.id}}" {{#unless mood.isAvailable}}disabled{{/unless}}>
                <i class="fas fa-music"></i> Mood anwenden
              </button>
            </li>
          {{/each}}
        {{else}}
          <li class="j7-text-dim">Keine belastbaren Mood-Vorschläge aus den aktuellen Daten ableitbar.</li>
        {{/if}}
      </ul>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-hourglass-half"></i> Nächste Slots</h3>
      <div class="j7-session-prep__timeline">
        {{#each view.upcoming as |slot|}}
          <article class="j7-timeline-card">
            <header>
              <strong>{{slot.slotRef.day}} · {{slot.slotRef.phase}}</strong>
              <span class="j7-text-dim">W{{slot.slotRef.week}}</span>
            </header>
            <ul>
              <li>Lessons: {{slot.lessons.length}}</li>
              <li>Exams: {{slot.exams.length}}</li>
              <li>Events: {{slot.events.length}}</li>
              <li>NSCs: {{slot.cast.length}}</li>
            </ul>
            {{#if slot.cast.length}}
              <p class="j7-text-dim">{{#each slot.cast as |npc|}}{{npc.name}}{{#unless @last}}, {{/unless}}{{/each}}</p>
            {{/if}}
          </article>
        {{/each}}
      </div>
    </section>
  </div>


  <section class="j7-panel">
    <h3><i class="fas fa-clipboard-list"></i> Szenen-Checkliste</h3>
    <div class="j7-seed-grid">
      {{#each view.sceneChecklist as |item|}}
        <article class="j7-seed-card">
          <header>
            <strong>{{item.label}}</strong>
            <span class="j7-text-dim">{{item.slotLabel}}</span>
          </header>
          <p><strong>Ort:</strong> {{item.locationName}}</p>
          <p><strong>Stimmung:</strong> {{item.moodLabel}}{{#if item.moodSource}} <span class="j7-text-dim">· {{item.moodSource}}</span>{{/if}}</p>
          <p><strong>Inhalte:</strong> {{#if item.contentTitles.length}}{{#each item.contentTitles as |title|}}{{title}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
          <p><strong>Besetzung:</strong> {{#if item.castNames.length}}{{#each item.castNames as |name|}}{{name}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
          <div class="j7-session-prep__footer-actions">
            <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="activateLocationScene" data-dataset-location-id="{{item.locationId}}" {{#unless item.locationId}}disabled{{/unless}}>
              <i class="fas fa-map"></i> Ort aktivieren
            </button>
            <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyLocationMood" data-dataset-location-id="{{item.locationId}}" {{#unless item.locationId}}disabled{{/unless}}>
              <i class="fas fa-music"></i> Orts-Mood
            </button>
            <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyMood" data-mood-id="{{item.moodId}}" {{#unless item.moodId}}disabled{{/unless}}>
              <i class="fas fa-wave-square"></i> Vorgeschlagene Stimmung
            </button>
          </div>
        </article>
      {{/each}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-list-ul"></i> Vorbereitungsagenda</h3>
    <div class="j7-seed-grid">
      {{#if view.prepAgenda.length}}
        {{#each view.prepAgenda as |item|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{item.slotLabel}} · {{item.typeLabel}}</strong>
              <span class="j7-text-dim">{{item.timeLabel}}</span>
            </header>
            <p><strong>{{item.title}}</strong></p>
            {{#if item.summary}}<p class="j7-text-dim">{{item.summary}}</p>{{/if}}
            {{#if item.focus}}<p><strong>Fokus:</strong> {{item.focus}}</p>{{/if}}
            {{#if item.teacherName}}<p><strong>Leitung:</strong> {{item.teacherName}}</p>{{/if}}
            <p><strong>Ort:</strong> {{item.locationName}}</p>
            <p><strong>Stimmung:</strong> {{item.moodLabel}}</p>
            {{#if item.questTitles.length}}<p><strong>Quest-Bezug:</strong> {{#each item.questTitles as |quest|}}{{quest}}{{#unless @last}}, {{/unless}}{{/each}}</p>{{/if}}
            {{#if item.storyThreads.length}}<p class="j7-text-dim"><strong>Threads:</strong> {{#each item.storyThreads as |thread|}}{{thread}}{{#unless @last}}, {{/unless}}{{/each}}</p>{{/if}}
            <ul class="j7-plain-list">
              {{#each item.detailBadges as |detail|}}<li>{{detail}}</li>{{/each}}
              {{#each item.notes as |note|}}<li class="j7-text-dim">{{note}}</li>{{/each}}
            </ul>
            <div class="j7-session-prep__footer-actions">
              {{#if item.lessonId}}
                <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="lesson.start" data-lesson-id="{{item.lessonId}}">
                  <i class="fas fa-book-open"></i> Lektion aktivieren
                </button>
              {{/if}}
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="activateLocationScene" data-dataset-location-id="{{item.locationId}}" {{#unless item.locationId}}disabled{{/unless}}>
                <i class="fas fa-map"></i> Ort
              </button>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyMood" data-mood-id="{{item.moodId}}" {{#unless item.moodId}}disabled{{/unless}}>
                <i class="fas fa-wave-square"></i> Stimmung
              </button>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="openEventPopup" data-event-id="{{item.currentEventId}}" data-actor-id="{{item.actorId}}" {{#unless item.currentEventId}}disabled{{/unless}}>
                <i class="fas fa-scroll"></i> Event
              </button>
            </div>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine belastbare Vorbereitungsagenda aus den aktuellen Slot-Daten ableitbar.</p>
      {{/if}}
    </div>
  </section>


  <section class="j7-panel">
    <h3><i class="fas fa-graduation-cap"></i> Pruefungsstand &amp; Notenbasis</h3>
    <p class="j7-text-dim">Schema: {{view.gradeOverview.schemeName}} · Eintraege: {{view.gradeOverview.summary.total}} · Exzellent: {{view.gradeOverview.summary.excellent}} · Bestanden: {{view.gradeOverview.summary.passed}} · Nicht bestanden: {{view.gradeOverview.summary.failed}}</p>
    <div class="j7-seed-grid">
      {{#if view.gradeOverview.items.length}}
        {{#each view.gradeOverview.items as |entry|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{entry.examTitle}}</strong>
              <span class="j7-text-dim">{{entry.attemptedAtLabel}}</span>
            </header>
            <p><strong>Akteur:</strong> {{entry.actorName}}</p>
            <p><strong>Ergebnis:</strong> {{entry.scoreLabel}}{{#if entry.percent}} <span class="j7-text-dim">· {{entry.percent}}%</span>{{/if}}</p>
            <p><strong>Status:</strong> {{entry.statusLabel}}</p>
            <p><strong>Note:</strong> {{#if entry.gradeLabel}}{{entry.gradeLabel}}{{else}}—{{/if}}{{#if entry.gradeBonus}} <span class="j7-text-dim">· Bonus {{entry.gradeBonus}}</span>{{/if}}</p>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine belastbare Notenbasis aus den aktuellen Pruefungsresultaten ableitbar.</p>
      {{/if}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-user-graduate"></i> Zwischenstand je Akteur</h3>
    <p class="j7-text-dim">Bezugsfenster: {{view.gradeLedger.periodLabel}} · Akteure: {{view.gradeLedger.summary.actorCount}} · Mit Periodenstempel: {{view.gradeLedger.summary.currentTrimesterTagged}}</p>
    <div class="j7-seed-grid">
      {{#if view.gradeLedger.items.length}}
        {{#each view.gradeLedger.items as |entry|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{entry.actorName}}</strong>
              <span class="j7-text-dim">{{entry.scopeLabel}}</span>
            </header>
            <p><strong>Pruefungen:</strong> {{entry.examsTaken}}</p>
            <p><strong>Mittelwert:</strong> {{entry.avgPercentLabel}}</p>
            <p><strong>Bonus-Saldo:</strong> {{entry.avgBonusLabel}}</p>
            <p><strong>Bestanden:</strong> {{entry.passedCount}} · <strong>Nicht bestanden:</strong> {{entry.failedCount}}</p>
            <p><strong>Letzte Pruefung:</strong> {{entry.latestExamTitle}}</p>
            <p class="j7-text-dim">{{entry.latestStatusLabel}} · {{entry.latestAttemptedAtLabel}}{{#if entry.untaggedCount}} · {{entry.untaggedCount}} ohne Periodenstempel{{/if}}</p>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine akteursbezogene Zwischenstandsaggregation aus den aktuellen Pruefungsresultaten ableitbar.</p>
      {{/if}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-scroll"></i> Trimesterwertung V1</h3>
    <p class="j7-text-dim">Schema: {{view.trimesterGrades.schemeName}} · Bezugsfenster: {{view.trimesterGrades.periodLabel}} · Akteure: {{view.trimesterGrades.summary.actorCount}} · Kritisch: {{view.trimesterGrades.summary.criticalCount}} · Vorlaeufig: {{view.trimesterGrades.summary.provisionalCount}}</p>
    <div class="j7-seed-grid">
      {{#if view.trimesterGrades.items.length}}
        {{#each view.trimesterGrades.items as |entry|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{entry.actorName}}</strong>
              <span class="j7-text-dim">{{entry.statusLabel}}</span>
            </header>
            <p><strong>Trimester-Note:</strong> {{entry.finalGradeLabel}}</p>
            <p><strong>Mittelwert:</strong> {{entry.avgPercentLabel}}</p>
            <p><strong>Bonus:</strong> {{entry.finalBonusLabel}}</p>
            <p><strong>Grundlage:</strong> {{entry.evidenceLabel}} · {{entry.confidenceLabel}}</p>
            <p><strong>Pruefungen:</strong> {{entry.supportingExamsLabel}}</p>
            <p class="j7-text-dim">Letzte Wertung: {{entry.latestExamTitle}} · {{entry.latestStatusLabel}}</p>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine trimesterbezogene Grades-V1-Auswertung aus den aktuellen Pruefungsresultaten ableitbar.</p>
      {{/if}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-address-card"></i> Zeugnis- & Journal-Entwuerfe</h3>
    <p class="j7-text-dim">Strukturierte Draft-Objekte pro Akteur als Vorstufe fuer spaetere Zeugnis-, Journal- oder PDF-Flows.</p>
    <div class="j7-seed-grid">
      {{#if view.reportCardDrafts.length}}
        {{#each view.reportCardDrafts as |draft|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{draft.title}}</strong>
              <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
            </header>
            <p><strong>Finale Note:</strong> {{draft.finalGradeLabel}}</p>
            <p><strong>Belastung:</strong> {{draft.evidenceLabel}} · {{draft.confidenceLabel}}</p>
            <p class="j7-text-dim">{{draft.statusLabel}}</p>
            <textarea rows="14">{{draft.text}}</textarea>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine strukturierten Zeugnis- oder Journal-Entwuerfe aus den aktuellen Grades-V1-Daten ableitbar.</p>
      {{/if}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-box-archive"></i> Zeugnis-/Journal-Export</h3>
    {{#if view.reportCardExportBundle}}
      <p class="j7-text-dim">Kanonisches Bundle fuer nachgelagerte Journal-, Datei- oder PDF-Flows. Akteure: {{view.reportCardExportBundle.summary.actorCount}} · Kritisch: {{view.reportCardExportBundle.summary.criticalCount}} · Vorlaeufig: {{view.reportCardExportBundle.summary.provisionalCount}}</p>
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>{{view.reportCardExportBundle.title}}</strong>
            <span>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="exportReportCardPdf"><i class="fas fa-file-pdf"></i> PDF öffnen</button>
              <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
            </span>
          </header>
          <textarea rows="16">{{view.reportCardExportBundle.text}}</textarea>
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Kein kanonisches Zeugnis-/Journal-Export-Bundle aus den aktuellen Draft-Daten ableitbar.</p>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-book-medical"></i> Zeugnis-Journal-Bundle</h3>
    {{#if view.reportCardJournalBundle}}
      <p class="j7-text-dim">Writer-orientierter Journal-Seed fuer spaetere JournalEntry-/Page-Erzeugung. Eintraege: {{view.reportCardJournalBundle.summary.entryCount}}</p>
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>{{view.reportCardJournalBundle.title}}</strong>
            <span>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="writeReportCardJournals"><i class="fas fa-book"></i> Journals schreiben</button>
              <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
            </span>
          </header>
          <textarea rows="16">{{view.reportCardJournalBundle.text}}</textarea>
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Kein writer-orientiertes Zeugnis-Journal-Bundle aus den aktuellen Exportdaten ableitbar.</p>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-file-signature"></i> Trimester-Export</h3>
    <p class="j7-text-dim">Kompakte Seeds pro Akteur als Vorstufe fuer spaetere Zeugnis-, Journal- oder KI-Weiterverarbeitung.</p>
    <div class="j7-seed-grid">
      {{#if view.gradeExportSeeds.length}}
        {{#each view.gradeExportSeeds as |seed|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{seed.title}}</strong>
              <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
            </header>
            <p class="j7-text-dim">{{seed.statusLabel}}</p>
            <textarea rows="11">{{seed.text}}</textarea>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine exportierbaren Trimester-Seeds aus den aktuellen Grades-V1-Daten ableitbar.</p>
      {{/if}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-bolt"></i> Akademie-Hooks ausspielen</h3>
    {{#if view.academyActionHooks}}
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>Queststarts</strong>
            <span class="j7-text-dim">{{view.academyActionHooks.questStarts.length}}</span>
          </header>
          {{#if view.academyActionHooks.questStarts.length}}
            <ul class="j7-plain-list">
              {{#each view.academyActionHooks.questStarts as |item|}}
                <li>
                  <strong>{{item.title}}</strong><br>
                  <span class="j7-text-dim">{{item.category}}{{#if item.tags.length}} · {{#each item.tags as |tag|}}{{tag}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</span><br>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="startQuest" data-quest-id="{{item.questId}}" data-actor-id="{{../view.academyActionHooks.defaultActorId}}">
                    <i class="fas fa-play"></i> Quest starten
                  </button>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="j7-text-dim">Keine startbaren Questpfade im Profilindex gefunden.</p>
          {{/if}}
        </article>

        <article class="j7-seed-card">
          <header>
            <strong>Event-Pools</strong>
            <span class="j7-text-dim">{{view.academyActionHooks.poolLaunchers.length}}</span>
          </header>
          {{#if view.academyActionHooks.poolLaunchers.length}}
            <ul class="j7-plain-list">
              {{#each view.academyActionHooks.poolLaunchers as |item|}}
                <li>
                  <strong>{{item.title}}</strong><br>
                  <span class="j7-text-dim">{{item.eventCount}} Events{{#if item.eventTitles.length}} · {{#each item.eventTitles as |title|}}{{title}}{{#unless @last}}, {{/unless}}{{/each}}{{/if}}</span><br>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="spawnEventFromPool" data-pool-id="{{item.poolId}}" data-actor-id="{{../view.academyActionHooks.defaultActorId}}">
                    <i class="fas fa-dice"></i> Pool ausspielen
                  </button>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="j7-text-dim">Keine spielbaren Event-Pools im Profilindex gefunden.</p>
          {{/if}}
        </article>

        <article class="j7-seed-card">
          <header>
            <strong>Aktuelle Event-Hooks</strong>
            <span class="j7-text-dim">{{view.academyActionHooks.currentEventLaunchers.length}}</span>
          </header>
          {{#if view.academyActionHooks.currentEventLaunchers.length}}
            <ul class="j7-plain-list">
              {{#each view.academyActionHooks.currentEventLaunchers as |item|}}
                <li>
                  <strong>{{item.title}}</strong><br>
                  <span class="j7-text-dim">{{item.type}}</span><br>
                  <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="openEventPopup" data-event-id="{{item.eventId}}" data-actor-id="{{../view.academyActionHooks.defaultActorId}}">
                    <i class="fas fa-scroll"></i> Event oeffnen
                  </button>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="j7-text-dim">Im aktuellen Slot liegen keine direkt oeffenbaren Event-Hooks.</p>
          {{/if}}
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Keine direkt ausspielbaren Akademie-Hooks aus den aktuellen Profildaten ableitbar.</p>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-school"></i> Akademie-Ueberblick</h3>
    {{#if view.academyOverview}}
      <p class="j7-text-dim">{{view.academyOverview.profileName}} · {{view.academyOverview.region}} · {{view.academyOverview.focus}}</p>
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>Bestand</strong>
            <span class="j7-text-dim">{{view.academyOverview.activeLocationName}}</span>
          </header>
          <ul class="j7-plain-list">
            <li>Lektionen: {{view.academyOverview.counts.lessons}}</li>
            <li>NPCs: {{view.academyOverview.counts.npcs}}</li>
            <li>Orte: {{view.academyOverview.counts.locations}}</li>
            <li>Events: {{view.academyOverview.counts.events}}</li>
            <li>Questpfade: {{view.academyOverview.counts.quests}}</li>
            <li>Event-Pools: {{view.academyOverview.counts.pools}}</li>
            <li>Fraktionen: {{view.academyOverview.counts.factions}}</li>
            <li>Social Links: {{view.academyOverview.counts.socialLinks}}</li>
            <li>Sessions jetzt: {{view.academyOverview.counts.currentSessions}}</li>
            <li>Offene Quests: {{view.academyOverview.counts.openQuests}}</li>
          </ul>
        </article>
        <article class="j7-seed-card">
          <header>
            <strong>Naechste Hooks</strong>
          </header>
          <p><strong>Unterricht:</strong> {{#if view.academyOverview.nextHooks.lessons.length}}{{#each view.academyOverview.nextHooks.lessons as |entry|}}{{entry}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
          <p><strong>Quests:</strong> {{#if view.academyOverview.nextHooks.quests.length}}{{#each view.academyOverview.nextHooks.quests as |entry|}}{{entry}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
          <p><strong>Fraktionen:</strong> {{#if view.academyOverview.nextHooks.factions.length}}{{#each view.academyOverview.nextHooks.factions as |entry|}}{{entry}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Kein belastbarer Akademie-Ueberblick aus den aktuellen Daten ableitbar.</p>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-bell"></i> Nachlaufende Konsequenzen</h3>
    <p class="j7-text-dim">Queue: {{view.academyFollowUp.summary.queuedEvents}} · Fraktionen: {{view.academyFollowUp.summary.factionPressure}} · Social: {{view.academyFollowUp.summary.socialPressure}} · Quests: {{view.academyFollowUp.summary.questPressure}}</p>
    <div class="j7-seed-grid">
      <article class="j7-seed-card">
        <header>
          <strong>Runtime-Queue</strong>
        </header>
        {{#if view.academyFollowUp.queuedEvents.length}}
          <ul class="j7-plain-list">
            {{#each view.academyFollowUp.queuedEvents as |item|}}
              <li>
                <strong>{{item.title}}</strong><br>
                <span class="j7-text-dim">{{item.source}} · {{item.detail}} · {{item.priorityLabel}}</span><br>
                <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="openEventPopup" data-event-id="{{item.eventId}}">
                  <i class="fas fa-scroll"></i> Event oeffnen
                </button>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Keine offenen Runtime-Queue-Eintraege.</p>
        {{/if}}
      </article>

      <article class="j7-seed-card">
        <header>
          <strong>Fraktionsdruck</strong>
        </header>
        {{#if view.academyFollowUp.factionPressure.length}}
          <ul class="j7-plain-list">
            {{#each view.academyFollowUp.factionPressure as |item|}}
              <li>
                <strong>{{item.name}}</strong><br>
                <span class="j7-text-dim">{{item.type}} · Punkte {{item.points}} · Ruf {{item.reputation}} · {{item.pressureLabel}}</span>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Kein akuter Fraktionsdruck im aktuellen Akademiestatus.</p>
        {{/if}}
      </article>

      <article class="j7-seed-card">
        <header>
          <strong>Social-Folgen</strong>
        </header>
        {{#if view.academyFollowUp.socialPressure.length}}
          <ul class="j7-plain-list">
            {{#each view.academyFollowUp.socialPressure as |item|}}
              <li>
                <strong>{{item.npcName}}</strong><br>
                <span class="j7-text-dim">Rang {{item.rank}}/{{item.maxRank}} · {{item.pressureLabel}}{{#if item.pendingEventId}} · {{item.pendingEventId}}{{/if}}</span>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Keine sichtbaren Social-Nachbeben im aktuellen Akademiestatus.</p>
        {{/if}}
      </article>

      <article class="j7-seed-card">
        <header>
          <strong>Quest-Nachbeben</strong>
        </header>
        {{#if view.academyFollowUp.questPressure.length}}
          <ul class="j7-plain-list">
            {{#each view.academyFollowUp.questPressure as |item|}}
              <li>
                <strong>{{item.title}}</strong><br>
                <span class="j7-text-dim">{{item.currentNodeTitle}} · {{item.pressureLabel}}</span>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="j7-text-dim">Keine aktiven Quest-Nachbeben im aktuellen Akademiestatus.</p>
        {{/if}}
      </article>
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-book-bookmark"></i> Chronik-Vorschau</h3>
    <div class="j7-seed-grid">
      {{#if view.chroniclePreview.length}}
        {{#each view.chroniclePreview as |entry|}}
          <article class="j7-seed-card">
            <header>
              <strong><i class="fas {{entry.icon}}"></i> {{entry.title}}</strong>
              <span class="j7-text-dim">{{entry.atLabel}}</span>
            </header>
            <p class="j7-text-dim">{{entry.category}}{{#if entry.detail}} · {{entry.detail}}{{/if}}{{#if entry.priorityLabel}} · {{entry.priorityLabel}}{{/if}}{{#if entry.hookStatusLabel}} · {{entry.hookStatusLabel}}{{/if}}</p>
            {{#if (and (eq entry.category 'social') entry.narrativePriority)}}
              <div class="j7-mt-sm">
                <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="queueSocialStoryHook" data-hook-id="{{entry.hookId}}" data-title="{{entry.title}}" data-detail="{{entry.detail}}" data-priority-label="{{entry.priorityLabel}}" data-from-id="{{entry.fromId}}" data-to-id="{{entry.toId}}" {{#if entry.hookQueued}}disabled{{/if}}>
                  <i class="fas fa-bookmark"></i> Als Story-Hook vormerken
                </button>
              </div>
            {{/if}}
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine belastbaren Chronik-Eintraege aus dem aktuellen State ableitbar.</p>
      {{/if}}
    </div>
  </section>


  <section class="j7-panel">
    <h3><i class="fas fa-bookmark"></i> Social-Story-Hook Queue</h3>
    <div class="j7-seed-grid">
      {{#if view.socialStoryHookQueue.items.length}}
        {{#each view.socialStoryHookQueue.items as |hook|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{hook.title}}</strong>
              <span class="j7-text-dim">{{hook.statusLabel}} · {{hook.updatedAtLabel}}</span>
            </header>
            <p class="j7-text-dim">{{hook.fromName}} -> {{hook.toName}} · {{hook.priorityLabel}}</p>
            <p>{{hook.detail}}</p>
            <div class="j7-mt-sm">
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setSocialStoryHookStatus" data-hook-id="{{hook.hookId}}" data-status="completed" {{#unless hook.isQueued}}disabled{{/unless}}>
                <i class="fas fa-check"></i> Abschliessen
              </button>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setSocialStoryHookStatus" data-hook-id="{{hook.hookId}}" data-status="discarded" {{#unless hook.isQueued}}disabled{{/unless}}>
                <i class="fas fa-ban"></i> Verwerfen
              </button>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="setSocialStoryHookStatus" data-hook-id="{{hook.hookId}}" data-status="queued" {{#if hook.isQueued}}disabled{{/if}}>
                <i class="fas fa-rotate-left"></i> Wieder oeffnen
              </button>
            </div>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Noch keine Social-Story-Hooks vorgemerkt.</p>
      {{/if}}
    </div>
    {{#if view.socialStoryHookQueue.summary.recentChanges.length}}
      <div class="j7-mt-sm">
        <p class="j7-text-dim">Letzte Queue-Aenderungen:</p>
        <ul class="j7-plain-list">
          {{#each view.socialStoryHookQueue.summary.recentChanges as |entry|}}
            <li class="j7-text-dim">{{entry.actionLabel}} · {{entry.changedAtLabel}}</li>
          {{/each}}
        </ul>
      </div>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-file-export"></i> Chronik-Export</h3>
    {{#if view.chronicleSeed}}
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>{{view.chronicleSeed.title}}</strong>
            <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
          </header>
          <textarea rows="14">{{view.chronicleSeed.text}}</textarea>
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Kein exportierbarer Chronik-Seed aus den aktuellen Daten ableitbar.</p>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-graduation-cap"></i> Akademie-Seed</h3>
    {{#if view.academySeed}}
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>{{view.academySeed.title}}</strong>
            <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
          </header>
          <textarea rows="14">{{view.academySeed.text}}</textarea>
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Kein exportierbarer Akademie-Seed aus den aktuellen Daten ableitbar.</p>
    {{/if}}
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-link"></i> Konsequenz-Seed</h3>
    {{#if view.consequenceSeed}}
      <div class="j7-seed-grid">
        <article class="j7-seed-card">
          <header>
            <strong>{{view.consequenceSeed.title}}</strong>
            <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
          </header>
          <textarea rows="12">{{view.consequenceSeed.text}}</textarea>
        </article>
      </div>
    {{else}}
      <p class="j7-text-dim">Kein exportierbarer Konsequenz-Seed aus den aktuellen Daten ableitbar.</p>
    {{/if}}
  </section>


  <section class="j7-panel">
    <h3><i class="fas fa-feather-pointed"></i> On-the-fly Content Seeds</h3>
    <div class="j7-seed-grid">
      {{#each view.contentSeeds as |seed|}}
        <article class="j7-seed-card">
          <header>
            <strong>{{seed.title}}</strong>
            <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
          </header>
          <textarea rows="7">{{seed.text}}</textarea>
        </article>
      {{/each}}
    </div>
  </section>

  <div class="j7-three-col">
    <section class="j7-panel">
      <h3><i class="fas fa-book"></i> Aktueller Slot</h3>
      <h4>Lessons</h4>
      <ul class="j7-plain-list">
        {{#if view.currentLessons.length}}
          {{#each view.currentLessons as |item|}}<li>{{item.title}} {{#if item.teacher}}<span class="j7-text-dim">· {{item.teacher}}</span>{{/if}}</li>{{/each}}
        {{else}}<li class="j7-text-dim">Keine Lektionen</li>{{/if}}
      </ul>
      <h4>Exams</h4>
      <ul class="j7-plain-list">
        {{#if view.currentExams.length}}
          {{#each view.currentExams as |item|}}<li>{{item.title}}</li>{{/each}}
        {{else}}<li class="j7-text-dim">Keine Prüfungen</li>{{/if}}
      </ul>
      <h4>Events</h4>
      <ul class="j7-plain-list">
        {{#if view.currentEvents.length}}
          {{#each view.currentEvents as |item|}}<li>{{item.title}}</li>{{/each}}
        {{else}}<li class="j7-text-dim">Keine Events</li>{{/if}}
      </ul>
      <h4>Besetzung</h4>
      <ul class="j7-plain-list">
        {{#if view.currentCast.length}}
          {{#each view.currentCast as |npc|}}
            <li>
              <strong>{{npc.name}}</strong>
              <span class="j7-text-dim">· {{npc.sourceType}} · {{npc.sourceLabel}}</span>
            </li>
          {{/each}}
        {{else}}<li class="j7-text-dim">Keine NSC-Besetzung aus dem Slot ableitbar.</li>{{/if}}
      </ul>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-scroll"></i> Offene Quests</h3>
      <p><strong>{{view.quests.total}}</strong> aktive Quest(s)</p>
      <ul class="j7-plain-list">
        {{#if view.quests.items.length}}
          {{#each view.quests.items as |item|}}
            <li>
              <strong>{{item.title}}</strong><br>
              <span class="j7-text-dim">{{item.actorId}} · Node: {{item.currentNodeTitle}}</span>
            </li>
          {{/each}}
        {{else}}
          <li class="j7-text-dim">Keine aktiven Quests.</li>
        {{/if}}
      </ul>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-triangle-exclamation"></i> Diagnostics</h3>
      <ul class="j7-plain-list">
        {{#if view.diagnostics.warnings.length}}
          {{#each view.diagnostics.warnings as |warn|}}<li>{{warn}}</li>{{/each}}
        {{else}}
          <li class="j7-text-dim">Keine aktuellen Warnungen.</li>
        {{/if}}
      </ul>
      <div class="j7-session-prep__footer-actions">
        <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="commandCenter"><i class="fas fa-terminal"></i> Power Tools</button>
      </div>
    </section>
  </div>
</div>
