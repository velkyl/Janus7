<div class="janus-session-prep janus7-page">
  <div class="janus7-toolbar">
    <div class="janus7-toolbar__left">
      <i class="fas fa-wand-sparkles"></i>
      <span class="janus7-title">Session Prep</span>
    </div>
    <div class="janus7-toolbar__right">
      <button type="button" class="janus-btn" data-action="executeShellAction" data-view-id="sessionPrep" title="Report neu generieren"><i class="fas fa-sync"></i> Refresh</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="academyOverview"><i class="fas fa-calendar-week"></i> Übersicht</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="atmosphereDJ"><i class="fas fa-music"></i> Atmosphäre</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="academyDataStudio"><i class="fas fa-edit"></i> Data Studio</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="kiRoundtrip"><i class="fas fa-brain"></i> KI</button>
      <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="kiBackupManager"><i class="fas fa-life-ring"></i> Backups</button>
    </div>
  </div>

  {{#unless view.isGM}}
    <div class="j7-backdrop j7-warn-banner"><i class="fas fa-exclamation-triangle"></i> Nur der GM kann Session Prep sinnvoll nutzen.</div>
  {{/unless}}

  <section class="j7-panel j7-session-prep__hero">
    <div>
      <h3><i class="fas fa-clock"></i> Aktueller Stand</h3>
      <p><strong>Woche {{view.slotRef.week}}</strong> · {{view.slotRef.day}} · {{view.slotRef.phase}}</p>
      <p class="j7-text-dim">Generiert: {{view.generatedAt}}</p>
    </div>
    <div>
      <h4><i class="fas fa-map-marker-alt"></i> Aktiver Ort</h4>
      {{#if view.activeLocation}}
        <p><strong>{{view.activeLocation.name}}</strong></p>
        <p class="j7-text-dim">Mood: {{view.activeLocation.defaultMoodKey}}</p>
      {{else}}
        <p class="j7-text-dim">Kein aktiver Ort gesetzt.</p>
      {{/if}}
    </div>
    <div>
      <h4><i class="fas fa-stethoscope"></i> Technik</h4>
      <p><strong>{{view.diagnostics.health}}</strong></p>
      <p class="j7-text-dim">Warnungen: {{view.diagnostics.warnings.length}}</p>
    </div>
  </section>

  <div class="j7-two-col">
    <section class="j7-panel">
      <h3><i class="fas fa-list-check"></i> Priorisierte To-dos</h3>
      <div class="j7-checklist">
        {{#each view.suggestions as |item|}}
          <article class="j7-checklist__item">
            <div class="j7-checklist__icon"><i class="fas {{item.icon}}"></i></div>
            <div>
              <strong>{{item.title}}</strong>
              <p>{{item.detail}}</p>
            </div>
          </article>
        {{/each}}
      </div>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-music"></i> Mood-Vorschläge</h3>
      <ul class="j7-plain-list">
        {{#if view.suggestedMoods.length}}
          {{#each view.suggestedMoods as |mood|}}
            <li>
              <strong>{{mood.label}}</strong>
              {{#if mood.isActive}}<span class="j7-text-dim"> · aktiv</span>{{/if}}<br>
              <span class="j7-text-dim">{{mood.source}} · {{mood.detail}}</span><br>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyMood" data-mood-id="{{mood.id}}" {{#unless mood.isAvailable}}disabled{{/unless}}>
                <i class="fas fa-music"></i> Mood anwenden
              </button>
            </li>
          {{/each}}
        {{else}}
          <li class="j7-text-dim">Keine belastbaren Mood-Vorschläge aus den aktuellen Daten ableitbar.</li>
        {{/if}}
      </ul>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-hourglass-half"></i> Nächste Slots</h3>
      <div class="j7-session-prep__timeline">
        {{#each view.upcoming as |slot|}}
          <article class="j7-timeline-card">
            <header>
              <strong>{{slot.slotRef.day}} · {{slot.slotRef.phase}}</strong>
              <span class="j7-text-dim">W{{slot.slotRef.week}}</span>
            </header>
            <ul>
              <li>Lessons: {{slot.lessons.length}}</li>
              <li>Exams: {{slot.exams.length}}</li>
              <li>Events: {{slot.events.length}}</li>
              <li>NSCs: {{slot.cast.length}}</li>
            </ul>
            {{#if slot.cast.length}}
              <p class="j7-text-dim">{{#each slot.cast as |npc|}}{{npc.name}}{{#unless @last}}, {{/unless}}{{/each}}</p>
            {{/if}}
          </article>
        {{/each}}
      </div>
    </section>
  </div>


  <section class="j7-panel">
    <h3><i class="fas fa-clipboard-list"></i> Szenen-Checkliste</h3>
    <div class="j7-seed-grid">
      {{#each view.sceneChecklist as |item|}}
        <article class="j7-seed-card">
          <header>
            <strong>{{item.label}}</strong>
            <span class="j7-text-dim">{{item.slotLabel}}</span>
          </header>
          <p><strong>Ort:</strong> {{item.locationName}}</p>
          <p><strong>Stimmung:</strong> {{item.moodLabel}}{{#if item.moodSource}} <span class="j7-text-dim">· {{item.moodSource}}</span>{{/if}}</p>
          <p><strong>Inhalte:</strong> {{#if item.contentTitles.length}}{{#each item.contentTitles as |title|}}{{title}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
          <p><strong>Besetzung:</strong> {{#if item.castNames.length}}{{#each item.castNames as |name|}}{{name}}{{#unless @last}}, {{/unless}}{{/each}}{{else}}—{{/if}}</p>
          <div class="j7-session-prep__footer-actions">
            <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="activateLocationScene" data-dataset-location-id="{{item.locationId}}" {{#unless item.locationId}}disabled{{/unless}}>
              <i class="fas fa-map"></i> Ort aktivieren
            </button>
            <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyLocationMood" data-dataset-location-id="{{item.locationId}}" {{#unless item.locationId}}disabled{{/unless}}>
              <i class="fas fa-music"></i> Orts-Mood
            </button>
            <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyMood" data-mood-id="{{item.moodId}}" {{#unless item.moodId}}disabled{{/unless}}>
              <i class="fas fa-wave-square"></i> Vorgeschlagene Stimmung
            </button>
          </div>
        </article>
      {{/each}}
    </div>
  </section>

  <section class="j7-panel">
    <h3><i class="fas fa-list-ul"></i> Vorbereitungsagenda</h3>
    <div class="j7-seed-grid">
      {{#if view.prepAgenda.length}}
        {{#each view.prepAgenda as |item|}}
          <article class="j7-seed-card">
            <header>
              <strong>{{item.slotLabel}} · {{item.typeLabel}}</strong>
              <span class="j7-text-dim">{{item.timeLabel}}</span>
            </header>
            <p><strong>{{item.title}}</strong></p>
            {{#if item.summary}}<p class="j7-text-dim">{{item.summary}}</p>{{/if}}
            {{#if item.focus}}<p><strong>Fokus:</strong> {{item.focus}}</p>{{/if}}
            {{#if item.teacherName}}<p><strong>Leitung:</strong> {{item.teacherName}}</p>{{/if}}
            <p><strong>Ort:</strong> {{item.locationName}}</p>
            <p><strong>Stimmung:</strong> {{item.moodLabel}}</p>
            <ul class="j7-plain-list">
              {{#each item.detailBadges as |detail|}}<li>{{detail}}</li>{{/each}}
              {{#each item.notes as |note|}}<li class="j7-text-dim">{{note}}</li>{{/each}}
            </ul>
            <div class="j7-session-prep__footer-actions">
              {{#if item.lessonId}}
                <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="lesson.start" data-lesson-id="{{item.lessonId}}">
                  <i class="fas fa-book-open"></i> Lektion aktivieren
                </button>
              {{/if}}
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="activateLocationScene" data-dataset-location-id="{{item.locationId}}" {{#unless item.locationId}}disabled{{/unless}}>
                <i class="fas fa-map"></i> Ort
              </button>
              <button type="button" class="janus-btn small" data-action="executeShellAction" data-command="applyMood" data-mood-id="{{item.moodId}}" {{#unless item.moodId}}disabled{{/unless}}>
                <i class="fas fa-wave-square"></i> Stimmung
              </button>
            </div>
          </article>
        {{/each}}
      {{else}}
        <p class="j7-text-dim">Keine belastbare Vorbereitungsagenda aus den aktuellen Slot-Daten ableitbar.</p>
      {{/if}}
    </div>
  </section>


  <section class="j7-panel">
    <h3><i class="fas fa-feather-pointed"></i> On-the-fly Content Seeds</h3>
    <div class="j7-seed-grid">
      {{#each view.contentSeeds as |seed|}}
        <article class="j7-seed-card">
          <header>
            <strong>{{seed.title}}</strong>
            <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
          </header>
          <textarea rows="7">{{seed.text}}</textarea>
        </article>
      {{/each}}
    </div>
  </section>

  <div class="j7-three-col">
    <section class="j7-panel">
      <h3><i class="fas fa-book"></i> Aktueller Slot</h3>
      <h4>Lessons</h4>
      <ul class="j7-plain-list">
        {{#if view.currentLessons.length}}
          {{#each view.currentLessons as |item|}}<li>{{item.title}} {{#if item.teacher}}<span class="j7-text-dim">· {{item.teacher}}</span>{{/if}}</li>{{/each}}
        {{else}}<li class="j7-text-dim">Keine Lektionen</li>{{/if}}
      </ul>
      <h4>Exams</h4>
      <ul class="j7-plain-list">
        {{#if view.currentExams.length}}
          {{#each view.currentExams as |item|}}<li>{{item.title}}</li>{{/each}}
        {{else}}<li class="j7-text-dim">Keine Prüfungen</li>{{/if}}
      </ul>
      <h4>Events</h4>
      <ul class="j7-plain-list">
        {{#if view.currentEvents.length}}
          {{#each view.currentEvents as |item|}}<li>{{item.title}}</li>{{/each}}
        {{else}}<li class="j7-text-dim">Keine Events</li>{{/if}}
      </ul>
      <h4>Besetzung</h4>
      <ul class="j7-plain-list">
        {{#if view.currentCast.length}}
          {{#each view.currentCast as |npc|}}
            <li>
              <strong>{{npc.name}}</strong>
              <span class="j7-text-dim">· {{npc.sourceType}} · {{npc.sourceLabel}}</span>
            </li>
          {{/each}}
        {{else}}<li class="j7-text-dim">Keine NSC-Besetzung aus dem Slot ableitbar.</li>{{/if}}
      </ul>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-scroll"></i> Offene Quests</h3>
      <p><strong>{{view.quests.total}}</strong> aktive Quest(s)</p>
      <ul class="j7-plain-list">
        {{#if view.quests.items.length}}
          {{#each view.quests.items as |item|}}
            <li>
              <strong>{{item.title}}</strong><br>
              <span class="j7-text-dim">{{item.actorId}} · Node: {{item.currentNodeTitle}}</span>
            </li>
          {{/each}}
        {{else}}
          <li class="j7-text-dim">Keine aktiven Quests.</li>
        {{/if}}
      </ul>
    </section>

    <section class="j7-panel">
      <h3><i class="fas fa-triangle-exclamation"></i> Diagnostics</h3>
      <ul class="j7-plain-list">
        {{#if view.diagnostics.warnings.length}}
          {{#each view.diagnostics.warnings as |warn|}}<li>{{warn}}</li>{{/each}}
        {{else}}
          <li class="j7-text-dim">Keine aktuellen Warnungen.</li>
        {{/if}}
      </ul>
      <div class="j7-session-prep__footer-actions">
        <button type="button" class="janus-btn" data-action="executeShellAction" data-app-key="commandCenter"><i class="fas fa-terminal"></i> Power Tools</button>
      </div>
    </section>
  </div>
</div>
