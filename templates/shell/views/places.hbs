<div class="j7-shell__view j7-shell__view--places">

  <div class="janus7-two-col">
    <!-- Active Ort -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-map-marker-alt j7-shell__card-icon" aria-hidden="true"></i><span>Aktiver Ort</span></h3>
          <p>Hier legst du Szenen ab um sie zu verknüpfen</p>
        </div>
      </header>
      <div class="j7-shell__metrics">
        <div class="j7-shell__metric"><span>Name</span><strong>{{view.locationView.activeLocationName}}</strong></div>
        <div class="j7-shell__metric"><span>ID</span><strong>{{view.locationView.activeLocationId}}</strong></div>
        <div class="j7-shell__metric"><span>Mood</span><strong>{{view.locationView.defaultMoodKey}}</strong></div>

        <div class="j7-dropzone j7-dropzone--medium j7-mt-sm" data-dropzone="location" data-location-id="{{view.locationView.activeLocationId}}">
          <div class="j7-dropzone__label"><i class="fas fa-link"></i> Scene/Playlist/Journal hier ablegen</div>
        </div>
      </div>

      <div class="j7-shell__card-actions j7-mt-sm">
        <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-command="activateLocationScene" data-dataset-location-id="{{view.locationView.activeLocationId}}"><i class="fas fa-map"></i> Scene aktivieren</button>
        <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-command="applyLocationMood" data-dataset-location-id="{{view.locationView.activeLocationId}}"><i class="fas fa-music"></i> Mood setzen</button>
      </div>
    </article>

    <!-- Alle Orte -->
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-layer-group j7-shell__card-icon" aria-hidden="true"></i><span>Alle Orte</span></h3>
        </div>
      </header>
      <div class="j7-shell__metrics">
        {{#if view.locationView.locations.length}}
          <ul class="janus7-list j7-mt-sm">
            {{#each view.locationView.locations}}
              <li class="j7-shell__list-row">
                <span>
                  <span class="j7-shell__badge">LOC</span> 
                  <strong>{{name}}</strong> 
                  <span class="muted j7-ml-sm">{{type}}</span>
                </span>
                {{#if hasScene}}
                  <button type="button" class="j7-shell__btn j7-shell__btn--primary" 
                          data-action="executeShellAction" 
                          data-command="viewScene" 
                          data-dataset-scene-id="{{sceneId}}"
                          title="Zur Szene: {{sceneName}}">
                    <i class="fas fa-eye"></i>
                  </button>
                {{/if}}
              </li>
            {{#each moduleContent.socialLinks}}
              <li class="j7-shell__list-row">
                <span>
                  <span class="j7-shell__badge j7-shell__badge--social">SOC</span> 
                  <strong>{{name}}</strong> 
                  <span class="muted j7-ml-sm">{{packLabel}}</span>
                </span>
                <button type="button" class="j7-shell__btn" 
                        data-action="openSheet" 
                        data-uuid="{{uuid}}"
                        title="Journal öffnen">
                  <i class="fas fa-book-open"></i>
                </button>
              </li>
            {{/each}}
          </ul>
        {{else}}
          <p class="muted">Keine Orte in den Akademie-Daten gefunden.</p>
        {{/if}}
      </div>
    </article>
  </div>

  <div class="j7-mt-sm">
    <article class="j7-shell__card j7-shell__card--wide">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-mug-hot j7-shell__card-icon" aria-hidden="true"></i><span>Regionale Treffpunkte & Gerüchteküche</span></h3>
          <p>Tavernen, Schänken und soziale Hubs aus den Modulen</p>
        </div>
      </header>
      <div class="j7-shell__status-grid">
        {{#each moduleContent.socialLinks}}
          <div class="j7-shell__status-item j7-shell__status-item--social">
             <div class="j7-shell__status-actor">
               <strong>{{name}}</strong>
               <span class="j7-badge">{{packLabel}}</span>
             </div>
             <div class="j7-shell__card-actions j7-mt-xs">
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="openSheet" data-uuid="{{uuid}}">
                 <i class="fas fa-eye"></i> Details
               </button>
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="executeShellAction" data-command="generateSocialRumor" data-dataset-location="{{name}}">
                 <i class="fas fa-comment-dots"></i> Gerücht
               </button>
             </div>
          </div>
        {{else}}
          <p class="muted j7-p-md">Keine sozialen Treffpunkte in den aktiven Modulen gefunden.</p>
        {{/each}}
      </div>
    </article>
  </div>

  <div class="j7-mt-sm">
    <article class="j7-shell__card j7-shell__card--wide">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-map-marked-alt j7-shell__card-icon" aria-hidden="true"></i><span>Regionale Karten & Visuals</span></h3>
          <p>Szenen, Stadtpläne und Übersichtskarten aus den Modulen</p>
        </div>
      </header>
      <div class="j7-shell__status-grid">
        {{#each (slice moduleContent.assets 0 8)}}
          <div class="j7-shell__status-item j7-shell__status-item--info">
             <div class="j7-shell__status-actor">
               <i class="fas fa-image j7-mr-sm"></i>
               <strong>{{name}}</strong>
               <span class="j7-badge">{{packLabel}}</span>
             </div>
             <div class="j7-shell__card-actions j7-mt-xs">
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="openSheet" data-uuid="{{uuid}}">
                 <i class="fas fa-eye"></i> Details
               </button>
               <button type="button" class="j7-shell__btn j7-shell__btn--small" data-action="executeShellAction" data-command="viewScene" data-dataset-scene-id="{{_id}}">
                 <i class="fas fa-external-link-alt"></i> Szene anzeigen
               </button>
             </div>
          </div>
        {{else}}
          <p class="muted j7-p-md">Keine Karten-Module oder Assets gefunden.</p>
        {{/each}}
      </div>
    </article>
  </div>
</div>
