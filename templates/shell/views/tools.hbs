<div class="j7-shell__view j7-shell__view--tools">
  {{#each view.cardSections}}
    <section class="j7-shell__section">
      <header class="j7-shell__section-head">
        <div>
          <h3>{{title}}</h3>
          <p>{{description}}</p>
        </div>
      </header>

      <div class="janus7-two-col">
        {{#each cards}}
          <article class="j7-shell__card">
            <header class="j7-shell__card-head">
              <div>
                <h3><i class="{{icon}} j7-shell__card-icon" aria-hidden="true"></i><span>{{title}}</span></h3>
                <p>{{description}}</p>
              </div>
            </header>

            {{#if metrics.length}}
              <div class="j7-shell__metrics">
                {{#each metrics}}
                  <div class="j7-shell__metric">
                    <span>{{label}}</span>
                    <strong>{{value}}</strong>
                  </div>
                {{/each}}
              </div>
            {{/if}}

            {{#if items.length}}
              <div class="j7-shell__list">
                {{#each items}}
                  <div class="j7-shell__list-row">
                    <span>{{label}}</span>
                    <strong>{{value}}</strong>
                  </div>
                {{/each}}
              </div>
            {{/if}}

            {{#if actions.length}}
              <div class="j7-shell__card-actions">
                {{#each actions}}
                  <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-section-id="{{../../id}}" data-action-index="{{actionIndex}}" data-card-index="{{../cardIndex}}">
                    <i class="{{icon}}"></i> {{label}}
                  </button>
                {{/each}}
              </div>
            {{/if}}
          </article>
        {{/each}}
      </div>
    </section>
  {{/each}}
</div>
