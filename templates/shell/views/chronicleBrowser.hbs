<div class="j7-shell__view j7-shell__view--chronicle-browser">
  {{#if unavailable}}
    <article class="j7-shell__card">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-triangle-exclamation j7-shell__card-icon" aria-hidden="true"></i><span>Bote-Chronik nicht verfuegbar</span></h3>
          <p>Die Daten konnten nicht geladen werden.</p>
        </div>
      </header>
      <p class="muted">{{error}}</p>
    </article>
  {{else}}
    <div class="janus7-two-col">
      <article class="j7-shell__card">
        <header class="j7-shell__card-head">
          <div>
            <h3><i class="fas fa-calendar-day j7-shell__card-icon" aria-hidden="true"></i><span>Fokusdatum</span></h3>
            <p>Aktueller BF-Tag aus dem State oder Fallback auf den Chronikbeginn.</p>
          </div>
        </header>
        <div class="j7-shell__metrics">
          <div class="j7-shell__metric"><span>Datum</span><strong>{{focusDate}}</strong></div>
          <div class="j7-shell__metric"><span>Tage gesamt</span><strong>{{summary.dayCount}}</strong></div>
          <div class="j7-shell__metric"><span>Basis/Tag</span><strong>{{summary.baseEntriesPerDay}}</strong></div>
          <div class="j7-shell__metric"><span>Kanonanker</span><strong>{{summary.curatedAnchorCount}}</strong></div>
          <div class="j7-shell__metric"><span>Meisterinfo-Anker</span><strong>{{summary.meisterinfoAnchorCount}}</strong></div>
        </div>
        <div class="j7-shell__card-actions j7-mt-sm">
          <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="offset" data-view-state-mode="delta" data-view-state-value="-1">
            <i class="fas fa-chevron-left"></i> Vorheriger Tag
          </button>
          <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="offset" data-view-state-mode="delta" data-view-state-value="1">
            <i class="fas fa-chevron-right"></i> Naechster Tag
          </button>
          <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="offset" data-view-state-value="0">
            <i class="fas fa-bullseye"></i> Zum State-Tag
          </button>
          <button type="button" class="j7-shell__btn" data-action="chroniclePickDate">
            <i class="fas fa-calendar-plus"></i> Datum waehlen
          </button>
          <button type="button" class="j7-shell__btn" data-action="chronicleJumpPeriod">
            <i class="fas fa-calendar-alt"></i> Monat/Jahr
          </button>
          <button type="button" class="j7-shell__btn" data-action="chronicleSearch">
            <i class="fas fa-search"></i> Suche
          </button>
        </div>
      </article>

      <article class="j7-shell__card">
        <header class="j7-shell__card-head">
          <div>
            <h3><i class="fas fa-road j7-shell__card-icon" aria-hidden="true"></i><span>Umgebungstage</span></h3>
            <p>Kurzer Browse-Fokus fuer die naheliegenden Chronikfenster.</p>
          </div>
        </header>
        {{#if nearbyDays.length}}
          <div class="j7-shell__list">
            {{#each nearbyDays}}
              <div class="j7-shell__list-row">
                <span>{{date}} · {{monthName}}</span>
                <strong>{{entryCount}} Eintraege{{#if anchorCount}} · {{anchorCount}} Anker{{/if}}</strong>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class="muted">Keine Nachbartage verfuegbar.</p>
        {{/if}}
      </article>
    </div>

    <article class="j7-shell__card j7-mt-sm">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-filter j7-shell__card-icon" aria-hidden="true"></i><span>Ortsfilter</span></h3>
          <p>Filtert Tageschronik, Monatsanker und Meisterinformationen auf Stadt oder Region.</p>
        </div>
      </header>
      <p class="j7-text-dim">Aktiver Filter: {{#if locationFilter}}{{locationFilter}}{{else}}alle Orte{{/if}}</p>
      <div class="j7-shell__card-actions j7-mt-sm" style="flex-wrap: wrap;">
        <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="location" data-view-state-mode="clear">
          <i class="fas fa-globe"></i> Alle Orte
        </button>
        {{#each availableLocations}}
          <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="location" data-view-state-value="{{this}}">
            <i class="fas fa-location-dot"></i> {{this}}
          </button>
        {{/each}}
      </div>
    </article>

    <article class="j7-shell__card j7-mt-sm">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-magnifying-glass j7-shell__card-icon" aria-hidden="true"></i><span>Suche & Tags</span></h3>
          <p>Durchsucht Labels, Beschreibungen, Orte und Tags der Chronik sowie Meisterinformationen.</p>
        </div>
      </header>
      <p class="j7-text-dim">Suchbegriff: {{#if search}}{{search}}{{else}}keiner{{/if}}{{#if tagFilter}} · Tag: {{tagFilter}}{{/if}}</p>
      <div class="j7-shell__card-actions j7-mt-sm" style="flex-wrap: wrap;">
        <button type="button" class="j7-shell__btn" data-action="chronicleSearch">
          <i class="fas fa-keyboard"></i> Suchbegriff setzen
        </button>
        <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="search" data-view-state-mode="clear">
          <i class="fas fa-eraser"></i> Suche leeren
        </button>
        <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="tag" data-view-state-mode="clear">
          <i class="fas fa-tags"></i> Alle Tags
        </button>
        {{#each availableTags}}
          <button type="button" class="j7-shell__btn" data-action="executeShellAction" data-target-view-id="chronicleBrowser" data-view-state-key="tag" data-view-state-value="{{this}}">
            <i class="fas fa-tag"></i> {{this}}
          </button>
        {{/each}}
      </div>
    </article>

    <article class="j7-shell__card j7-mt-sm">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-file-export j7-shell__card-icon" aria-hidden="true"></i><span>Export</span></h3>
          <p>Kopierbarer Seed der aktuell gefilterten Chronikansicht.</p>
        </div>
        <div class="j7-shell__card-actions">
          <button type="button" class="janus-btn small" data-action="chronicleSelectCalendarImport"><i class="fas fa-book-open-reader"></i> DSA5-Kalenderquelle</button>
          <button type="button" class="janus-btn small" data-action="chronicleClearCalendarImport"><i class="fas fa-link-slash"></i> Quelle loesen</button>
        </div>
      </header>
      <p class="j7-text-dim">
        Kalenderquelle:
        {{#if importedCalendarJournal}}
          {{importedCalendarJournal.name}} · {{importedCalendarSummary.total}} Eintraege · {{importedCalendarSummary.focusDay}} am Fokus-Tag
        {{else}}
          keine
        {{/if}}
      </p>
      {{#if chronicleExportSeed}}
        <div class="j7-seed-grid">
          <article class="j7-seed-card">
            <header>
              <strong>{{chronicleExportSeed.title}}</strong>
              <div class="j7-shell__card-actions">
                <button type="button" class="janus-btn small" data-action="copySeed"><i class="fas fa-copy"></i> Kopieren</button>
                <button type="button" class="janus-btn small" data-action="chronicleExportCalendar"><i class="fas fa-calendar-plus"></i> In DSA5-Kalender</button>
              </div>
            </header>
            <textarea rows="16">{{chronicleExportSeed.text}}</textarea>
          </article>
        </div>
      {{else}}
        <p class="muted">Kein exportierbarer Seed verfuegbar.</p>
      {{/if}}
    </article>

    <article class="j7-shell__card j7-mt-sm">
      <header class="j7-shell__card-head">
        <div>
          <h3><i class="fas fa-book-bookmark j7-shell__card-icon" aria-hidden="true"></i><span>Eintraege am Fokusdatum</span></h3>
          <p>Mehrere Taegeseintraege aus der verdichteten Bote-Chronik.</p>
        </div>
      </header>
      {{#if focusDay}}
        <div class="j7-seed-grid">
          {{#if focusDay.entries.length}}
            {{#each focusDay.entries}}
              <article class="j7-seed-card">
                <header>
                  <strong>{{label}}</strong>
                  <span class="j7-text-dim">{{category}} · {{sourceType}}</span>
                </header>
                <p class="j7-text-dim">{{location}}{{#if tags}} · {{tags}}{{/if}}</p>
                <p>{{description}}</p>
              </article>
            {{/each}}
          {{else}}
            <p class="muted">Fuer den Fokus-Tag sind keine Eintraege vorhanden.</p>
          {{/if}}
        </div>
      {{else}}
        <p class="muted">Fuer den Fokus-Tag sind keine Eintraege vorhanden.</p>
      {{/if}}
    </article>

    <div class="janus7-two-col j7-mt-sm">
      <article class="j7-shell__card">
        <header class="j7-shell__card-head">
          <div>
            <h3><i class="fas fa-anchor j7-shell__card-icon" aria-hidden="true"></i><span>Monatsanker</span></h3>
            <p>Tage im aktuellen BF-Monat mit kuratierten oder meisterinformationsbasierten Zusatzankern.</p>
          </div>
          <div class="j7-shell__card-actions">
            <button type="button" class="janus-btn small" data-action="chronicleExportMonthCalendar"><i class="fas fa-calendar-plus"></i> Monat in DSA5-Kalender</button>
          </div>
        </header>
        {{#if monthlyAnchors.length}}
          <div class="j7-shell__list">
            {{#each monthlyAnchors}}
              <div class="j7-shell__list-row">
                <span>{{date}}</span>
                <strong>{{anchorEntries.length}} Anker</strong>
              </div>
              <ul class="janus7-list">
                {{#each anchorEntries}}
                  <li><span class="tag">{{sourceType}}</span> <strong>{{label}}</strong> {{#if location}}· {{location}}{{/if}}</li>
                {{/each}}
              </ul>
            {{/each}}
          </div>
        {{else}}
          <p class="muted">Im aktuellen BF-Monat wurden keine Zusatzanker gefunden.</p>
        {{/if}}
      </article>

      <article class="j7-shell__card">
        <header class="j7-shell__card-head">
          <div>
            <h3><i class="fas fa-scroll j7-shell__card-icon" aria-hidden="true"></i><span>Meisterinformationen im Jahr</span></h3>
            <p>Aus den Bote-PDFs extrahierte Hooks fuer das aktuelle BF-Jahr.</p>
          </div>
        </header>
        {{#if yearlyMasterHooks.length}}
          <div class="j7-seed-grid">
            {{#each yearlyMasterHooks}}
              <article class="j7-seed-card">
                <header>
                  <strong>{{title}}</strong>
                  <span class="j7-text-dim">{{issue}}</span>
                </header>
                <p class="j7-text-dim">{{location}}{{#if approximateDate}} · {{approximateDate}}{{/if}}{{#if tags}} · {{tags}}{{/if}}</p>
                <p>{{hook}}</p>
              </article>
            {{/each}}
          </div>
        {{else}}
          <p class="muted">Fuer dieses BF-Jahr liegen keine Meisterinformations-Hooks vor.</p>
        {{/if}}
      </article>
    </div>
  {{/if}}
</div>
