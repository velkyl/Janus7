
<section class="j7-shell__root janus-shell-app" aria-label="JANUS7 Shell Layer">
  <header class="j7-shell__header">
    <div class="j7-shell__brand">
      <div class="j7-shell__brand-title">JANUS7</div>
      <div class="j7-shell__brand-meta">{{header.moduleVersion}} · {{header.worldTitle}}</div>
    </div>
    <div class="j7-shell__status">
      <span class="j7-shell__status-pill">{{header.dayName}}</span>
      <span class="j7-shell__status-pill">{{header.phaseName}}</span>
      <span class="j7-shell__status-pill j7-shell__status-pill--accent">{{header.activeViewTitle}}</span>
    </div>
    <div class="j7-shell__header-actions">
      {{#each header.quickPanels}}
        <button type="button" class="j7-shell__quick" data-action="openPanel" data-panel-id="{{id}}" title="{{title}}">
          <i class="{{icon}} j7-shell__quick-icon" aria-hidden="true"></i>
        </button>
      {{/each}}
      <button type="button" class="j7-shell__command" data-action="togglePalette">{{shellPaletteHint}}</button>
    </div>
  </header>

  {{#if header.lastActionResult}}
    <div class="j7-shell__flash">{{header.lastActionResult}}</div>
  {{/if}}

  <div class="j7-shell__body">
    <aside class="j7-shell__sidebar janus-shell__nav" aria-label="Views">
      {{#each views}}
        <button type="button"
                class="j7-shell__nav {{#if isActive}}is-active{{/if}}"
                data-action="selectView"
                data-view-id="{{id}}"
                aria-pressed="{{#if isActive}}true{{else}}false{{/if}}">
          <i class="{{icon}} j7-shell__nav-icon" aria-hidden="true"></i>
          <span class="j7-shell__nav-copy">
            <strong>{{title}}</strong>
            <small>{{description}}</small>
          </span>
        </button>
      {{/each}}
    </aside>

    <main class="j7-shell__content" aria-label="View Content">
      {{{viewHtml}}}
    </main>

    {{#if panelOpen}}
      <section class="j7-shell__panelHost" aria-label="Aktives Panel">
        {{{panelHtml}}}
      </section>
    {{/if}}
  </div>
</section>
