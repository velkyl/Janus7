<div class="j7-shell__panel">
  <header class="j7-shell__panel-head">
    <div>
      <h3><i class="{{panel.icon}} j7-shell__panel-icon" aria-hidden="true"></i><span>{{panel.title}}</span></h3>
      <p>{{panel.description}}</p>
    </div>
    <button type="button" class="j7-shell__panel-close" data-action="closePanel" aria-label="Panel schliessen">&times;</button>
  </header>

  <div class="j7-shell__panel-summary">{{panel.summary}}</div>

  {{#if metrics.length}}
    <div class="j7-shell__metrics">
      {{#each metrics}}
        <div class="j7-shell__metric">
          <span>{{label}}</span>
          <strong>{{value}}</strong>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{#if items.length}}
    <div class="j7-shell__list">
      {{#each items}}
        <div class="j7-shell__list-row">
          <span>{{label}}</span>
          <strong>{{value}}</strong>
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{#if actions.length}}
    <div class="j7-shell__panel-actions">
      {{#each actions}}
        <button type="button"
                class="j7-shell__btn j7-shell__btn--primary"
                data-action="executeShellAction"
                data-panel-id="{{../panel.id}}"
                data-action-index="{{actionIndex}}">
          <i class="{{actionIcon}}"></i>{{actionLabel}}
        </button>
      {{/each}}
    </div>
  {{/if}}
</div>
