{"_id": "ALPhCmooCpFsegRV", "name": "JANUS7 – Atmosphere: Enable", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.janus7?.core?.state) return ui.notifications.error(\"JANUS7: Core State nicht verfügbar.\");\nif (!game.user?.isGM) return ui.notifications.warn(\"JANUS7: Nur GM darf Atmosphere aktivieren.\");\nawait game.janus7.core.state.transaction(async (s) => {\n  s.set(\"features.atmosphere.enabled\", true);\n});\nawait game.janus7.core.state.save({ force: true });\nui.notifications.info(\"JANUS7: Atmosphere aktiviert.\");\n", "folder": null, "sort": 10, "ownership": {"default": 0}, "flags": {}}
{"_id": "YGknlQr2XlK51jOr", "name": "JANUS7 – Atmosphere: Disable", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.janus7?.core?.state) return ui.notifications.error(\"JANUS7: Core State nicht verfügbar.\");\nif (!game.user?.isGM) return ui.notifications.warn(\"JANUS7: Nur GM darf Atmosphere deaktivieren.\");\nawait game.janus7.core.state.transaction(async (s) => {\n  s.set(\"features.atmosphere.enabled\", false);\n  s.set(\"atmosphere.activeMoodId\", null);\n});\nawait game.janus7.core.state.save({ force: true });\ntry { await game.janus7.atmosphere.stopAll({ broadcast: true }); } catch (e) {}\nui.notifications.info(\"JANUS7: Atmosphere deaktiviert und Audio gestoppt.\");\n", "folder": null, "sort": 20, "ownership": {"default": 0}, "flags": {}}
{"_id": "BXUCnn85KWY3Jogf", "name": "JANUS7 – Atmosphere: Set Master (Self)", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.janus7?.atmosphere?.setMasterClient) return ui.notifications.error(\"JANUS7: Atmosphere API nicht verfügbar.\");\nif (!game.user?.isGM) return ui.notifications.warn(\"JANUS7: Nur GM darf den Master setzen.\");\nawait game.janus7.atmosphere.setMasterClient(game.user.id, { broadcast: true });\nui.notifications.info(`JANUS7: Master-Client gesetzt: ${game.user.name}`);\n", "folder": null, "sort": 30, "ownership": {"default": 0}, "flags": {}}
{"_id": "73UE0v6IRFTetGbP", "name": "JANUS7 – Atmosphere: Apply Mood…", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.janus7?.atmosphere?.applyMood) return ui.notifications.error(\"JANUS7: Atmosphere API nicht verfügbar.\");\nif (!game.user?.isGM) return ui.notifications.warn(\"JANUS7: Nur GM darf Moods wechseln.\");\n\nconst content = `\n<form>\n  <div class=\"form-group\">\n    <label>Mood ID</label>\n    <input type=\"text\" name=\"moodId\" placeholder=\"z.B. academy_day\" autofocus/>\n    <p class=\"notes\">Die Mood-IDs stehen in <code>data/academy/atmosphere/moods.json</code>.</p>\n  </div>\n</form>\n`;\n\nnew Dialog({\n  title: \"JANUS7: Mood anwenden\",\n  content,\n  buttons: {\n    apply: {\n      icon: '<i class=\"fas fa-check\"></i>',\n      label: \"Anwenden\",\n      callback: async (html) => {\n        const moodId = html.find('input[name=\"moodId\"]').val()?.trim();\n        if (!moodId) return ui.notifications.warn(\"JANUS7: Bitte eine Mood ID eingeben.\");\n        await game.janus7.atmosphere.applyMood(moodId, { broadcast: true });\n        ui.notifications.info(`JANUS7: Mood angewendet: ${moodId}`);\n      }\n    },\n    cancel: { icon: '<i class=\"fas fa-times\"></i>', label: \"Abbrechen\" }\n  },\n  default: \"apply\"\n}).render(true);\n", "folder": null, "sort": 40, "ownership": {"default": 0}, "flags": {}}
{"_id": "JNalLS7CyKmtT6uj", "name": "JANUS7 – Atmosphere: Stop All", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.janus7?.atmosphere?.stopAll) return ui.notifications.error(\"JANUS7: Atmosphere API nicht verfügbar.\");\nif (!game.user?.isGM) return ui.notifications.warn(\"JANUS7: Nur GM darf Audio stoppen.\");\nawait game.janus7.atmosphere.stopAll({ broadcast: true });\nui.notifications.info(\"JANUS7: Stop All ausgeführt.\");\n", "folder": null, "sort": 50, "ownership": {"default": 0}, "flags": {}}
{"_id": "kari88HOikFhQQk5", "name": "JANUS7 – Atmosphere: Status", "type": "script", "scope": "global", "img": "icons/svg/eye.svg", "command": "const ctl = game?.janus7?.atmosphere?.controller;\nif (!ctl) return ui.notifications.warn(\"JANUS7: Atmosphere-Controller nicht gefunden.\");\nconst st = ctl.status();\nconsole.log(\"JANUS7 Atmosphere Status\", st);\nui.notifications.info(`JANUS7 Atmosphere: enabled=${st.enabled}, master=${st.masterClientUserId ?? \"—\"}, isMaster=${st.isMaster}, mood=${st.activeMoodId ?? \"—\"}, auto=${st.autoFromCalendar}`);", "folder": null, "sort": 60, "ownership": {"default": 0}, "flags": {}}
{"_id": "IgnQ5ja6C2wtfeey", "name": "JANUS7 – Atmosphere: Toggle Auto (Calendar)", "type": "script", "scope": "global", "img": "icons/svg/sun.svg", "command": "const ctl = game?.janus7?.atmosphere?.controller;\nif (!ctl) return ui.notifications.warn(\"JANUS7: Atmosphere-Controller nicht gefunden.\");\nif (!game.user.isGM) return ui.notifications.warn(\"JANUS7: Nur GM.\");\nconst st = ctl.status();\nconst next = !st.autoFromCalendar;\nawait ctl.setAutoFromCalendar(next, { broadcast: true });\nui.notifications.info(`JANUS7: Auto-Moods ${next ? \"aktiviert\" : \"deaktiviert\"} (Calendar).`);", "folder": null, "sort": 55, "ownership": {"default": 0}, "flags": {}}
{"_id": "mFACXRnp0xCzhhRQ", "name": "JANUS7 – Atmosphere: Set Master…", "type": "script", "scope": "global", "img": "icons/svg/crown.svg", "command": "const ctl = game?.janus7?.atmosphere?.controller;\nif (!ctl) return ui.notifications.warn(\"JANUS7: Atmosphere-Controller nicht gefunden.\");\nif (!game.user.isGM) return ui.notifications.warn(\"JANUS7: Nur GM.\");\nconst users = game.users?.filter(u => u.active) ?? [];\nconst options = users.map(u => `<option value=\"${u.id}\">${u.name}${u.isGM ? \" (GM)\" : \"\"}</option>`).join(\"\");\nnew Dialog({\n  title: \"JANUS7 – Set Atmosphere Master\",\n  content: `<p>Wähle den Master-Client (Audio läuft nur dort).</p><div class=\"form-group\"><label>User</label><select id=\"j7Master\">${options}</select></div>`,\n  buttons: {\n    ok: { label: \"Setzen\", callback: async (html) => {\n      const uid = html.find(\"#j7Master\").val();\n      await game.janus7.atmosphere.setMasterClient(uid, { broadcast: true });\n      ui.notifications.info(\"JANUS7: Master-Client gesetzt.\");\n    }},\n    clear: { label: \"Entfernen\", callback: async () => {\n      await game.janus7.atmosphere.setMasterClient(null, { broadcast: true });\n      ui.notifications.info(\"JANUS7: Master-Client entfernt.\");\n    }},\n    cancel: { label: \"Abbrechen\" }\n  },\n  default: \"ok\"\n}).render(true);", "folder": null, "sort": 35, "ownership": {"default": 0}, "flags": {}}
{"_id": "7TqbWd4K0XUudlyU", "name": "JANUS7 – Atmosphere: Toggle Auto (Events)", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.user?.isGM) return ui.notifications.warn(\"Nur GM.\");\nconst cur = !!game.janus7?.core?.state?.get?.(\"atmosphere.autoFromEvents\");\nawait game.janus7.atmosphere.setAutoFromEvents(!cur, { broadcast: true });\nui.notifications.info(`JANUS7: Auto (Events) ${(cur ? \"deaktiviert\" : \"aktiviert\")}.`);\n", "folder": null, "sort": 90, "ownership": {"default": 0}, "flags": {}}
{"_id": "LHoOYtVO2E3QXaTK", "name": "JANUS7 – Atmosphere: Toggle Auto (Location)", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.user?.isGM) return ui.notifications.warn(\"Nur GM.\");\nconst cur = !!game.janus7?.core?.state?.get?.(\"atmosphere.autoFromLocation\");\nawait game.janus7.atmosphere.setAutoFromLocation(!cur, { broadcast: true });\nui.notifications.info(`JANUS7: Auto (Location) ${(cur ? \"deaktiviert\" : \"aktiviert\")}.`);\n", "folder": null, "sort": 100, "ownership": {"default": 0}, "flags": {}}
{"_id": "f6ihBuwZDA4vBqbK", "name": "JANUS7 – Atmosphere: Master Volume…", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.user?.isGM) return ui.notifications.warn(\"Nur GM.\");\nconst current = Number(game.janus7?.core?.state?.get?.(\"atmosphere.masterVolume\") ?? 1);\nconst content = `<p>Master-Volume (0..1):</p><input type=\"number\" step=\"0.05\" min=\"0\" max=\"1\" value=\"${current}\"/>`;\nnew Dialog({\n  title: \"JANUS7 – Atmosphere: Master Volume\",\n  content,\n  buttons: {\n    ok: { label: \"Setzen\", callback: async (html) => {\n      const v = Number(html.find('input').val());\n      await game.janus7.atmosphere.setMasterVolume(v, { broadcast: true });\n      ui.notifications.info(`JANUS7: Master-Volume = ${v}`);\n    }},\n    cancel: { label: \"Abbrechen\" }\n  }\n}).render(true);\n", "folder": null, "sort": 110, "ownership": {"default": 0}, "flags": {}}
{"_id": "lgueLgLoRSVcduSE", "name": "JANUS7 – Atmosphere: Pause", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.user?.isGM) return ui.notifications.warn(\"Nur GM.\");\nawait game.janus7.atmosphere.pause({ broadcast: true, fadeOutMs: 800 });\nui.notifications.info(\"JANUS7: Atmosphere pausiert.\");\n", "folder": null, "sort": 120, "ownership": {"default": 0}, "flags": {}}
{"_id": "pkAIF6CMYaUYlxcv", "name": "JANUS7 – Atmosphere: Resume", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.user?.isGM) return ui.notifications.warn(\"Nur GM.\");\nawait game.janus7.atmosphere.resume({ broadcast: true, fadeInMs: 800 });\nui.notifications.info(\"JANUS7: Atmosphere resumed.\");\n", "folder": null, "sort": 130, "ownership": {"default": 0}, "flags": {}}
{"_id": "xUBWFUV2s2szE98Z", "name": "JANUS7 – Location: Set Current…", "type": "script", "scope": "global", "img": "icons/svg/sound.svg", "command": "if (!game?.user?.isGM) return ui.notifications.warn(\"Nur GM.\");\nconst engine = game.janus7?.academy?.locations || game.janus7?.simulation?.locations;\nif (!engine?.listLocations) return ui.notifications.error(\"JANUS7: LocationsEngine nicht verfügbar.\");\nconst locations = engine.listLocations() || [];\nconst cur = engine.getCurrentLocationId?.() ?? null;\nconst options = ['<option value=\"\">(kein Ort)</option>'].concat(locations.map(l => {\n  const id = l.id; const name = l.name ?? id;\n  return `<option value=\"${id}\" ${id===cur?'selected':''}>${name}</option>`;\n})).join('');\nconst content = `<p>Aktuellen Ort setzen:</p><select style=\"width:100%\">${options}</select>`;\nnew Dialog({\n  title: \"JANUS7 – Set Location\",\n  content,\n  buttons: {\n    ok: { label: \"Setzen\", callback: async (html) => {\n      const id = html.find('select').val();\n      await engine.setCurrentLocation(id || null, { broadcast: true });\n      ui.notifications.info(`JANUS7: Ort gesetzt: ${id || '(kein Ort)'}`);\n    }},\n    cancel: { label: \"Abbrechen\" }\n  }\n}).render(true);\n", "folder": null, "sort": 140, "ownership": {"default": 0}, "flags": {}}