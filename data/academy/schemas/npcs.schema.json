{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JANUS Academy NPCs",
  "type": "object",
  "required": [
    "npcs"
  ],
  "properties": {
    "npcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      }
    }
  }
}