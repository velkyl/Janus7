{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JANUS Academy Lessons",
  "type": "object",
  "required": [
    "meta",
    "lessons"
  ],
  "properties": {
    "meta": {
      "type": "object"
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "subject"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "teacherNpcId": {
            "type": [
              "string",
              "null"
            ]
          },
          "references": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    }
  }
}
