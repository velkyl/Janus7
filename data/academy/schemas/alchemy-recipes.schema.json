{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JANUS Academy Alchemy Recipes",
  "type": "object",
  "required": [
    "meta",
    "recipes"
  ],
  "properties": {
    "meta": {
      "type": "object"
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "foundry": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    }
  }
}
