{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JANUS Academy Teaching Sessions",
  "type": "object",
  "required": [
    "meta",
    "sessions"
  ],
  "properties": {
    "meta": {
      "type": "object"
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "planId",
          "day",
          "subject",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "planId": {
            "type": "string"
          },
          "day": {
            "type": "string"
          },
          "slotId": {
            "type": [
              "string",
              "null"
            ]
          },
          "subject": {
            "type": "string"
          },
          "subjectKey": {
            "type": [
              "string",
              "null"
            ]
          },
          "npcIdCandidates": {
            "type": [
              "array",
              "null"
            ]
          },
          "locationIdCandidates": {
            "type": [
              "array",
              "null"
            ]
          }
        }
      }
    }
  }
}
