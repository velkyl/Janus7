{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JANUS Academy Library",
  "type": "object",
  "required": [
    "meta",
    "items"
  ],
  "properties": {
    "meta": {
      "type": "object"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "foundry": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    }
  }
}
