{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JANUS Academy School Stats",
  "type": "object",
  "required": [
    "meta",
    "stats"
  ],
  "properties": {
    "meta": {
      "type": "object"
    },
    "stats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "min",
          "max"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          }
        }
      }
    }
  }
}
